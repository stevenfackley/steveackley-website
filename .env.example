# Environment Variables Example

# --- Database ---
# Existing PostgreSQL (EC2)
DATABASE_URL=postgresql://user:password@host:port/dbname

# --- Authentication (Better-Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4321

# Admin credentials (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# --- Storage (Cloudflare R2) ---
# Public bucket recommended for images
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# --- GitHub API (for blog/projects fetching) ---
# Personal Access Token (classic) with repo scope
GH_API_TOKEN=

# --- Public URLs (Astro/Vite: PUBLIC_ prefix is exposed to the browser) ---
PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/yourprofile
PUBLIC_EMAIL=your@email.com
PUBLIC_P1_OPS_HUB_URL=
