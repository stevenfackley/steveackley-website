# =============================================================================
# Environment Variables for Cloudflare Tunnel Deployment
# Copy this file to .env and fill in your values
# =============================================================================

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Get this token from Cloudflare Dashboard → Zero Trust → Access → Tunnels
# After creating a tunnel, copy the token that looks like:
# eyJhIjoixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx...
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_DB=steveackley
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_database_password_here

# Used by the Next.js app to connect to PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ── NextAuth.js (Authentication) ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_32_character_secret_here

# Your public domain URL (used for callbacks, CSRF validation)
AUTH_URL=https://aws.steveackley.org

# ── Admin User ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=stevenfackley@gmail.com

# Generate with: npm run setup:admin
# Or manually: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$your_bcrypt_hash_here

# ── Public Variables (Safe for client-side) ─────────────────────────────────
PUBLIC_LINKEDIN_URL=https://linkedin.com/in/steveackley
PUBLIC_EMAIL=stevenfackley@gmail.com
PUBLIC_P1_OPS_HUB_URL=https://p1opshub.com

# ── Upload Configuration ─────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=5
