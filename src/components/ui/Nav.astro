---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/resume', label: 'Resume' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
const isHomePage = currentPath === '/';
const isResumePage = currentPath === '/resume' || currentPath === '/resume/';
const hideNameInitially = isHomePage || isResumePage;
const placeholderAvatar = 'https://github.com/stevenfackley.png';
---

<nav class="sticky top-0 z-50 border-b border-[var(--border)] bg-[var(--background)]/90 backdrop-blur-md">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-14 items-center justify-between gap-4">
      <!-- Logo / Name -->
      <a
        href="/"
        id="nav-name"
        class:list={[
          'flex items-center gap-2.5 group transition-all duration-300 ease-out',
          hideNameInitially
            ? 'opacity-0 -translate-y-1 pointer-events-none'
            : 'opacity-100 translate-y-0',
        ]}
      >
        <img
          src={placeholderAvatar}
          alt="Steve Ackley"
          width="28"
          height="28"
          class="rounded-full ring-1 ring-[var(--border)] group-hover:ring-[var(--accent)] transition-all duration-150 object-cover"
        />
        <span class="text-sm font-semibold tracking-tight text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors duration-150">
          Steve Ackley
        </span>
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden sm:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm px-3 py-1.5 rounded-lg transition-colors duration-150',
              currentPath === link.href
                ? 'text-[var(--accent)] bg-[var(--surface-hover)]'
                : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-hover)]',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/admin/login"
          class="ml-2 text-sm px-3 py-1.5 rounded-lg flex items-center gap-1.5 text-[var(--text-muted)] hover:text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] border border-[var(--border)] hover:border-[var(--border-hover)] transition-all duration-150"
          title="Sign In"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
            <path fill-rule="evenodd" d="M8 1a3.5 3.5 0 0 0-3.5 3.5V6H4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-.5V4.5A3.5 3.5 0 0 0 8 1ZM6 4.5a2 2 0 1 1 4 0V6H6V4.5Z" clip-rule="evenodd" />
          </svg>
          <span class="text-xs hidden sm:inline">Sign In</span>
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden p-2 rounded-lg text-[var(--text-secondary)] hover:bg-[var(--surface-hover)]"
        aria-label="Toggle menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="sm:hidden hidden pb-4 border-t border-[var(--border)] mt-2 pt-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-3 py-2 text-sm rounded-lg transition-colors',
            currentPath === link.href
              ? 'text-[var(--accent)] bg-[var(--surface-hover)]'
              : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-hover)]',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/admin/login" class="block px-3 py-2 text-sm rounded-lg text-[var(--text-muted)] hover:text-[var(--text-secondary)] hover:bg-[var(--surface-hover)]">
        Sign In
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Reveal nav name when the page's hero heading scrolls out of view.
  // Works for both the home page (#hero-name) and the resume page (#resume-hero-name).
  const heroName = document.getElementById('hero-name') ?? document.getElementById('resume-hero-name');
  const navName = document.getElementById('nav-name');

  if (heroName && navName) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          // Hero name scrolled past — reveal nav name
          navName.classList.remove('opacity-0', '-translate-y-1', 'pointer-events-none');
          navName.classList.add('opacity-100', 'translate-y-0');
        } else {
          // Hero name visible — hide nav name
          navName.classList.add('opacity-0', '-translate-y-1', 'pointer-events-none');
          navName.classList.remove('opacity-100', 'translate-y-0');
        }
      },
      {
        // Trigger slightly before the element fully leaves the viewport
        rootMargin: '-56px 0px 0px 0px', // account for nav height
        threshold: 0,
      }
    );

    observer.observe(heroName);
  }
</script>
