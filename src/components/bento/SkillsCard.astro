---
import { cn } from '@/lib/utils';
import Card from '@/components/ui/Card.astro';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const skills = [
  { name: 'C# / .NET',          level: 5 },
  { name: 'Azure Cloud',        level: 5 },
  { name: 'SQL Server',         level: 5 },
  { name: 'ASP.NET / Web API',  level: 5 },
  { name: 'Angular',            level: 4 },
  { name: 'Docker / DevOps',    level: 4 },
];
---

<Card class={cn('p-6', className)}>
  <div class="flex items-center justify-between mb-3">
    <span class="text-xs font-medium tracking-widest uppercase text-[var(--text-muted)]">Skills & Stack</span>
  </div>
  <ul class="space-y-3 mt-2">
    {skills.map((skill) => (
      <li>
        <div class="flex items-center justify-between mb-1">
          <span class="text-sm text-[var(--text-secondary)]">{skill.name}</span>
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map((_, i) => (
              <span
                class="h-1.5 w-4 rounded-full transition-colors"
                style={i < skill.level
                  ? 'background: linear-gradient(90deg, #2563eb, #7c3aed)'
                  : 'background: var(--border)'}
              ></span>
            ))}
          </div>
        </div>
      </li>
    ))}
  </ul>
</Card>
