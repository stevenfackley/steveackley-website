---
import { cn, formatDateShort } from '@/lib/utils';

interface Props {
  class?: string;
  posts: any[];
}

const { class: className, posts } = Astro.props;
---

<div class={cn('p-6 bg-gradient-to-br from-purple-50 to-blue-50 dark:from-purple-950/30 dark:to-blue-950/30 rounded-2xl border border-purple-200 dark:border-purple-800', className)}>
  <div class="flex items-center gap-2 mb-4">
    <span class="text-2xl">✍️</span>
    <h2 class="text-xl font-semibold">Recent Posts</h2>
  </div>
  
  {posts.length > 0 ? (
    <ul class="space-y-3">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`} class="block group hover:bg-white/50 dark:hover:bg-white/5 rounded-lg p-2 -m-2 transition-colors">
            <h3 class="font-medium group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors line-clamp-1">
              {post.title}
            </h3>
            <p class="text-sm text-neutral-600 dark:text-neutral-400">{formatDateShort(post.createdAt)}</p>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="text-sm text-neutral-600 dark:text-neutral-400 py-4">No posts yet. Stay tuned!</p>
  )}
  
  <a href="/blog" class="text-sm text-purple-600 dark:text-purple-400 hover:underline mt-4 inline-block">
    View all posts →
  </a>
</div>
