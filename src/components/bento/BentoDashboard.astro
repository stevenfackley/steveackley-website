---
import HeroCard from './HeroCard.astro';
import SkillsCard from './SkillsCard.astro';
import AboutCard from './AboutCard.astro';
import ProjectsCard from './ProjectsCard.astro';
import BlogPreviewCard from './BlogPreviewCard.astro';
import CTACard from './CTACard.astro';

interface Props {
  blogPosts: any[];
  githubRepos: any[];
  avatarUrl: string;
  couplePhotoUrl: string;
}

const { blogPosts, githubRepos, avatarUrl, couplePhotoUrl } = Astro.props;
---

<div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
  <HeroCard class="lg:col-span-2" avatarUrl={avatarUrl} />
  <SkillsCard />
  <AboutCard couplePhotoUrl={couplePhotoUrl} />
  <ProjectsCard class="lg:col-span-2" repos={githubRepos} />
  <BlogPreviewCard class="lg:col-span-2" posts={blogPosts} />
  <CTACard />
</div>
