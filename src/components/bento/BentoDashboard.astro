---
import { TabsDashboard } from './TabsDashboard';
import type { PostSummary } from '@/types';
import type { EnrichedRepo } from '@/lib/github';

interface Props {
  blogPosts: Pick<PostSummary, "id" | "title" | "slug" | "excerpt" | "createdAt">[];
  githubRepos: EnrichedRepo[];
  avatarUrl: string;
  couplePhotoUrl: string;
}

const { blogPosts, githubRepos, avatarUrl, couplePhotoUrl } = Astro.props;
---

<TabsDashboard
  client:only="react"
  blogPosts={blogPosts}
  githubRepos={githubRepos}
  avatarUrl={avatarUrl}
  couplePhotoUrl={couplePhotoUrl}
/>
