---
import { TabsDashboard } from './TabsDashboard';

interface Props {
  blogPosts: any[];
  githubRepos: any[];
  avatarUrl: string;
  couplePhotoUrl: string;
}

const { blogPosts, githubRepos, avatarUrl, couplePhotoUrl } = Astro.props;
---

<TabsDashboard
  client:only="react"
  blogPosts={blogPosts}
  githubRepos={githubRepos}
  avatarUrl={avatarUrl}
  couplePhotoUrl={couplePhotoUrl}
/>
