---
import { cn, formatDateShort } from '@/lib/utils';
import type { PostSummary } from '@/types';

interface Props {
  post: PostSummary;
  class?: string;
}

const { post, class: className } = Astro.props;
---

<article class={cn('group bg-[var(--surface)] border border-[var(--border)] rounded-2xl overflow-hidden hover:border-[var(--border-hover)] hover:-translate-y-0.5 transition-all duration-200', className)}>
  {post.coverImage && (
    <div class="relative h-48 overflow-hidden">
      <img src={post.coverImage} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
    </div>
  )}
  <div class="p-5">
    <time class="text-xs text-[var(--text-muted)]">{formatDateShort(post.createdAt)}</time>
    <h2 class="mt-1.5 text-base font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors line-clamp-2">
      <a href={`/blog/${post.slug}`}>{post.title}</a>
    </h2>
    {post.excerpt && <p class="mt-2 text-sm text-[var(--text-secondary)] line-clamp-3 leading-relaxed">{post.excerpt}</p>}
    <a href={`/blog/${post.slug}`} class="mt-4 inline-flex text-xs font-medium text-[var(--accent)] hover:text-[var(--accent-hover)] transition-colors">Read more →</a>
  </div>
</article>
