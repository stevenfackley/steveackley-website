---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db, users } from '@/db';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

// Handle form submission
let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const name = String(form.get('name') ?? '').trim();
    const image = String(form.get('image') ?? '').trim();

    await db.update(users).set({
      name: name || null,
      image: image || null,
    }).where(eq(users.id, user.id));

    successMessage = 'Account updated successfully.';
  } catch (e) {
    errorMessage = 'Failed to save changes.';
  }
}

// Re-fetch current user
const [currentUser] = await db.select().from(users).where(eq(users.id, user.id)).limit(1);
---

<AdminLayout title="Account">
  <div class="max-w-2xl space-y-8">

    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-[var(--text-primary)]">My Account</h1>
      <p class="text-[var(--text-secondary)] mt-1.5">Manage your admin profile</p>
    </div>

    {successMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-emerald-200 bg-emerald-50 dark:border-emerald-800 dark:bg-emerald-950/50 px-4 py-3 text-sm text-emerald-700 dark:text-emerald-300">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
        {successMessage}
      </div>
    )}
    {errorMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-red-200 bg-red-50 dark:border-red-800 dark:bg-red-950/50 px-4 py-3 text-sm text-red-700 dark:text-red-300">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
        {errorMessage}
      </div>
    )}

    <!-- Profile card -->
    <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-6">
      <div class="flex items-center gap-5 mb-6 pb-6 border-b border-[var(--border)]">
        <div class="relative shrink-0">
          <img
            src={currentUser?.image || `https://ui-avatars.com/api/?name=${encodeURIComponent(currentUser?.name || 'Admin')}&background=2563eb&color=fff&size=80`}
            alt="Avatar"
            class="h-20 w-20 rounded-2xl object-cover ring-2 ring-[var(--border)]"
          />
        </div>
        <div>
          <p class="text-lg font-bold text-[var(--text-primary)]">{currentUser?.name || 'Admin'}</p>
          <p class="text-sm text-[var(--text-muted)]">{currentUser?.email}</p>
          <span class="mt-1 inline-flex items-center gap-1 rounded-full bg-blue-100 dark:bg-blue-950 px-2.5 py-0.5 text-xs font-semibold text-blue-700 dark:text-blue-300">
            {currentUser?.role}
          </span>
        </div>
      </div>

      <form method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Display Name</label>
          <input
            type="text"
            name="name"
            value={currentUser?.name ?? ''}
            class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
            placeholder="Steve Ackley"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Email Address</label>
          <input
            type="email"
            value={currentUser?.email ?? ''}
            disabled
            class="w-full rounded-xl border border-[var(--border)] bg-[var(--surface-hover)] px-3 py-2.5 text-sm text-[var(--text-muted)] cursor-not-allowed"
          />
          <p class="text-xs text-[var(--text-muted)] mt-1">Email cannot be changed here.</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Avatar URL</label>
          <input
            type="url"
            name="image"
            value={currentUser?.image ?? ''}
            class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
            placeholder="https://..."
          />
        </div>
        <div class="pt-1">
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
          >
            Save Changes
          </button>
        </div>
      </form>
    </div>

    <!-- Danger zone -->
    <div class="bg-[var(--surface)] border border-red-200 dark:border-red-900/50 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-red-600 dark:text-red-400 uppercase tracking-widest mb-3">Session</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">Sign out of the admin portal on this device.</p>
      <a
        href="/api/auth/sign-out"
        class="inline-flex items-center gap-2 rounded-xl border border-red-300 dark:border-red-800 px-5 py-2.5 text-sm font-bold text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/40 transition-colors"
      >
        Sign Out
      </a>
    </div>

  </div>
</AdminLayout>
