---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db, siteSettings } from '@/db';
import { SETTING_KEYS, DEFAULTS } from '@/lib/setting-keys';
import { getSiteSettings } from '@/lib/settings';
import { SettingsUploadField } from '@/components/admin/SettingsUploadField';
import { SettingsPreview } from '@/components/admin/SettingsPreview';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const updates = [
      { key: SETTING_KEYS.AVATAR_URL,       value: String(form.get('avatar_url') ?? '').trim() },
      { key: SETTING_KEYS.COUPLE_PHOTO_URL,  value: String(form.get('couple_photo_url') ?? '').trim() },
      { key: SETTING_KEYS.BIO_TEXT,          value: String(form.get('bio_text') ?? '').trim() },
      { key: SETTING_KEYS.HERO_TAGLINE,      value: String(form.get('hero_tagline') ?? '').trim() },
      { key: SETTING_KEYS.SITE_THEME,        value: String(form.get('site_theme') ?? 'light').trim() },
    ];

    for (const { key, value } of updates) {
      await db
        .insert(siteSettings)
        .values({ key, value })
        .onConflictDoUpdate({ target: siteSettings.key, set: { value } });
    }

    successMessage = 'Settings saved successfully.';
  } catch (e) {
    errorMessage = 'Failed to save settings.';
  }
}

const settings = await getSiteSettings(Object.values(SETTING_KEYS));
const currentTheme = settings[SETTING_KEYS.SITE_THEME] || 'light';
---

<AdminLayout title="Settings">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    
    <!-- Left column: Settings form -->
    <div class="space-y-8">

      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-[var(--text-primary)]">Site Settings</h1>
        <p class="text-[var(--text-secondary)] mt-1.5">Manage public-facing content, media, and appearance</p>
      </div>

    {successMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
        {successMessage}
      </div>
    )}
    {errorMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
        {errorMessage}
      </div>
    )}

    <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-6">
      <form method="POST" class="space-y-6">

        <!-- ── Appearance ─────────────────────────────────────── -->
        <div>
          <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest mb-4">Appearance</h2>

          <!-- Site Default Theme -->
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-2">
              Site Default Theme
            </label>
            <div class="flex items-center gap-3">
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="radio"
                  name="site_theme"
                  value="light"
                  checked={currentTheme === 'light'}
                  class="accent-[var(--accent)]"
                />
                <span class="flex items-center gap-1.5 text-sm text-[var(--text-secondary)]">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 text-amber-500">
                    <path d="M10 2a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 2zM10 15a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 15zM10 7a3 3 0 100 6 3 3 0 000-6z"/>
                  </svg>
                  Light
                </span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="radio"
                  name="site_theme"
                  value="dark"
                  checked={currentTheme === 'dark'}
                  class="accent-[var(--accent)]"
                />
                <span class="flex items-center gap-1.5 text-sm text-[var(--text-secondary)]">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 text-indigo-400">
                    <path fill-rule="evenodd" d="M7.455 2.004a.75.75 0 01.26.77 7 7 0 009.958 7.967.75.75 0 011.067.853A8.5 8.5 0 116.647 1.921a.75.75 0 01.808.083z" clip-rule="evenodd" />
                  </svg>
                  Dark
                </span>
              </label>
            </div>
            <p class="text-xs text-[var(--text-muted)] mt-1.5">
              Default theme for visitors who haven't set a personal preference. Individual users can always toggle with the button in the nav.
            </p>
          </div>
        </div>

        <hr class="border-[var(--border)]" />

        <!-- ── Media ──────────────────────────────────────────── -->
        <div>
          <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest mb-4">Media</h2>

          <!-- Avatar URL with upload -->
          <div class="mb-5">
            <SettingsUploadField
              client:load
              name="avatar_url"
              label="Avatar / Profile Photo"
              defaultValue={settings[SETTING_KEYS.AVATAR_URL] ?? ''}
              placeholder={DEFAULTS[SETTING_KEYS.AVATAR_URL]}
            />
            <p class="text-xs text-[var(--text-muted)] mt-1">Shown in the hero section. Paste a URL or upload a file.</p>
          </div>

          <!-- Couple Photo URL with upload -->
          <div>
            <SettingsUploadField
              client:load
              name="couple_photo_url"
              label="Couple / Secondary Photo"
              defaultValue={settings[SETTING_KEYS.COUPLE_PHOTO_URL] ?? ''}
              placeholder="https://..."
            />
            <p class="text-xs text-[var(--text-muted)] mt-1">Photo shown in the About bento card. Paste a URL or upload a file.</p>
          </div>
        </div>

        <hr class="border-[var(--border)]" />

        <!-- ── Content ────────────────────────────────────────── -->
        <div>
          <h2 class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-widest mb-4">Content</h2>

          <!-- Bio Text -->
          <div class="mb-5">
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Bio Text</label>
            <textarea
              name="bio_text"
              rows={3}
              class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors resize-y"
              placeholder={DEFAULTS[SETTING_KEYS.BIO_TEXT]}
            >{settings[SETTING_KEYS.BIO_TEXT]}</textarea>
            <p class="text-xs text-[var(--text-muted)] mt-1">Short bio shown in the About section.</p>
          </div>

          <!-- Hero Tagline -->
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Hero Tagline</label>
            <textarea
              name="hero_tagline"
              rows={3}
              class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors resize-y"
              placeholder={DEFAULTS[SETTING_KEYS.HERO_TAGLINE]}
            >{settings[SETTING_KEYS.HERO_TAGLINE]}</textarea>
            <p class="text-xs text-[var(--text-muted)] mt-1">Shown beneath your name in the hero card.</p>
          </div>
        </div>

        <div class="pt-1">
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" /></svg>
            Save Settings
          </button>
        </div>

      </form>
    </div>

    </div>
    
    <!-- Right column: Preview -->
    <div class="space-y-8">
      <div class="lg:sticky lg:top-8">
        <div class="mb-6">
          <h2 class="text-xl font-bold tracking-tight text-[var(--text-primary)]">Preview</h2>
          <p class="text-[var(--text-secondary)] text-sm mt-1">Live preview of your settings</p>
        </div>
        <SettingsPreview client:load settings={settings} />
      </div>
    </div>

  </div>
</AdminLayout>
