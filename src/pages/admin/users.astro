---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db, users } from '@/db';
import { eq, desc } from 'drizzle-orm';
import bcrypt from 'bcryptjs';

const adminUser = Astro.locals.user;
if (!adminUser) return Astro.redirect('/admin/login');

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('_action') ?? '');

  try {
    if (action === 'create') {
      const email = String(form.get('email') ?? '').trim().toLowerCase();
      const name = String(form.get('name') ?? '').trim();
      const password = String(form.get('password') ?? '');
      const role = String(form.get('role') ?? 'CLIENT') as 'ADMIN' | 'CLIENT';
      const companyName = String(form.get('companyName') ?? '').trim();
      const contactFirstName = String(form.get('contactFirstName') ?? '').trim();
      const contactLastName = String(form.get('contactLastName') ?? '').trim();

      if (!email || !password) throw new Error('Email and password are required.');
      if (password.length < 8) throw new Error('Password must be at least 8 characters.');

      // Check duplicate
      const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, email)).limit(1);
      if (existing.length > 0) throw new Error('A user with that email already exists.');

      const passwordHash = await bcrypt.hash(password, 12);
      const userId = crypto.randomUUID();

      await db.insert(users).values({
        id: userId,
        email,
        name: name || null,
        passwordHash,
        role,
        companyName: companyName || null,
        contactFirstName: contactFirstName || null,
        contactLastName: contactLastName || null,
        emailVerified: false,
      });

      // Also create a credential account record for better-auth
      const { accounts } = await import('@/db');
      await db.insert(accounts).values({
        id: crypto.randomUUID(),
        accountId: userId,
        providerId: 'credential',
        userId,
        password: passwordHash,
        createdAt: new Date(),
        updatedAt: new Date(),
      });

      successMessage = `User "${email}" created successfully.`;

    } else if (action === 'update') {
      const userId = String(form.get('userId') ?? '');
      const name = String(form.get('name') ?? '').trim();
      const role = String(form.get('role') ?? 'CLIENT') as 'ADMIN' | 'CLIENT';
      const companyName = String(form.get('companyName') ?? '').trim();
      const contactFirstName = String(form.get('contactFirstName') ?? '').trim();
      const contactLastName = String(form.get('contactLastName') ?? '').trim();
      const newPassword = String(form.get('newPassword') ?? '');

      if (!userId) throw new Error('User ID is required.');

      if (newPassword) {
        if (newPassword.length < 8) throw new Error('Password must be at least 8 characters.');
        const passwordHash = await bcrypt.hash(newPassword, 12);
        const { accounts } = await import('@/db');
        await db.update(accounts).set({ password: passwordHash }).where(eq(accounts.userId, userId));
        await db.update(users).set({
          name: name || null, role, companyName: companyName || null,
          contactFirstName: contactFirstName || null, contactLastName: contactLastName || null,
          passwordHash,
        }).where(eq(users.id, userId));
      } else {
        await db.update(users).set({
          name: name || null, role, companyName: companyName || null,
          contactFirstName: contactFirstName || null, contactLastName: contactLastName || null,
        }).where(eq(users.id, userId));
      }
      successMessage = 'User updated successfully.';

    } else if (action === 'delete') {
      const userId = String(form.get('userId') ?? '');
      if (!userId) throw new Error('User ID is required.');
      if (userId === adminUser.id) throw new Error('You cannot delete your own account.');
      await db.delete(users).where(eq(users.id, userId));
      successMessage = 'User deleted.';
    }
  } catch (e) {
    errorMessage = e instanceof Error ? e.message : 'An error occurred.';
  }
}

// Fetch all users
const allUsers = await db.select().from(users).orderBy(desc(users.createdAt));

const editUserId = Astro.url.searchParams.get('edit');
const editUser = editUserId ? allUsers.find(u => u.id === editUserId) : null;

const searchQ = (Astro.url.searchParams.get('q') ?? '').toLowerCase();
const filteredUsers = searchQ
  ? allUsers.filter(u =>
      (u.email ?? '').toLowerCase().includes(searchQ) ||
      (u.name ?? '').toLowerCase().includes(searchQ) ||
      (u.companyName ?? '').toLowerCase().includes(searchQ)
    )
  : allUsers;

const PAGE_SIZE = 20;
const currentPage = Math.max(0, parseInt(Astro.url.searchParams.get('page') ?? '0'));
const totalPages = Math.ceil(filteredUsers.length / PAGE_SIZE);
const pagedUsers = filteredUsers.slice(currentPage * PAGE_SIZE, (currentPage + 1) * PAGE_SIZE);
---

<AdminLayout title="Users">
  <div class="space-y-6">

    <div class="flex items-center justify-between flex-wrap gap-3">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-[var(--text-primary)]">Users</h1>
        <p class="text-[var(--text-secondary)] mt-1.5">{filteredUsers.length} of {allUsers.length} user{allUsers.length !== 1 ? 's' : ''}</p>
      </div>
      <a
        href="?create=1"
        class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        New User
      </a>
    </div>

    {successMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
        {successMessage}
      </div>
    )}
    {errorMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
        {errorMessage}
      </div>
    )}

    <!-- Create / Edit Form -->
    {(Astro.url.searchParams.has('create') || editUser) && (
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-6">
        <h2 class="text-lg font-bold text-[var(--text-primary)] mb-5">
          {editUser ? `Edit User: ${editUser.name || editUser.email}` : 'Create New User'}
        </h2>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="_action" value={editUser ? 'update' : 'create'} />
          {editUser && <input type="hidden" name="userId" value={editUser.id} />}

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {!editUser && (
              <div>
                <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Email <span class="text-red-500">*</span></label>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                  placeholder="user@example.com"
                />
              </div>
            )}
            {editUser && (
              <div>
                <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Email</label>
                <input
                  type="email"
                  value={editUser.email}
                  disabled
                  class="w-full rounded-xl border border-[var(--border)] bg-[var(--surface-hover)] px-3 py-2.5 text-sm text-[var(--text-muted)] cursor-not-allowed"
                />
              </div>
            )}
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Display Name</label>
              <input
                type="text"
                name="name"
                value={editUser?.name ?? ''}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Jane Smith"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">
                {editUser ? 'New Password (leave blank to keep)' : 'Password *'}
              </label>
              <input
                type="password"
                name={editUser ? 'newPassword' : 'password'}
                required={!editUser}
                minlength={8}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Min 8 characters"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Role</label>
              <select
                name="role"
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
              >
                <option value="CLIENT" selected={!editUser || editUser.role === 'CLIENT'}>Client</option>
                <option value="ADMIN" selected={editUser?.role === 'ADMIN'}>Admin</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Company Name</label>
              <input
                type="text"
                name="companyName"
                value={editUser?.companyName ?? ''}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Acme Corp"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Contact First Name</label>
              <input
                type="text"
                name="contactFirstName"
                value={editUser?.contactFirstName ?? ''}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Jane"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Contact Last Name</label>
              <input
                type="text"
                name="contactLastName"
                value={editUser?.contactLastName ?? ''}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Smith"
              />
            </div>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
            >
              {editUser ? 'Save Changes' : 'Create User'}
            </button>
            <a href="/admin/users" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors">
              Cancel
            </a>
          </div>
        </form>
      </div>
    )}

    <!-- Search -->
    <form method="GET" class="flex items-center gap-2">
      {editUserId && <input type="hidden" name="edit" value={editUserId} />}
      <input
        type="search"
        name="q"
        value={searchQ}
        placeholder="Search users…"
        class="w-full max-w-sm rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
      />
      <button type="submit" class="rounded-xl border border-[var(--border)] bg-[var(--surface-hover)] px-3 py-2 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Search</button>
      {searchQ && <a href="/admin/users" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors">Clear</a>}
    </form>

    <!-- Users Table -->
    <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl overflow-hidden">
      {allUsers.length === 0 ? (
        <div class="p-12 flex flex-col items-center text-center gap-3">
          <div class="h-12 w-12 rounded-full bg-[var(--surface-hover)] flex items-center justify-center">
            <svg class="h-6 w-6 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <p class="text-sm font-medium text-[var(--text-primary)]">No users yet</p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-[var(--border)] bg-[var(--surface-hover)]">
                <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wide">User</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wide hidden sm:table-cell">Role</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wide hidden md:table-cell">Company</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wide hidden lg:table-cell">Joined</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wide">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[var(--border)]">
              {pagedUsers.map((u) => (
                <tr class="hover:bg-[var(--surface-hover)] transition-colors">
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-3">
                      <div class="h-8 w-8 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-xs font-bold uppercase shrink-0">
                        {(u.name || u.email || '?').charAt(0)}
                      </div>
                      <div>
                        <p class="font-medium text-[var(--text-primary)]">{u.name || '—'}</p>
                        <p class="text-xs text-[var(--text-muted)]">{u.email}</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-3 hidden sm:table-cell">
                    <span class:list={[
                      'inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold',
                      u.role === 'ADMIN'
                        ? 'bg-purple-100 text-purple-700'
                        : 'bg-blue-100 text-blue-700',
                    ]}>
                      {u.role}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm text-[var(--text-secondary)] hidden md:table-cell">
                    {u.companyName || '—'}
                  </td>
                  <td class="px-4 py-3 text-xs text-[var(--text-muted)] hidden lg:table-cell">
                    {u.createdAt.toLocaleDateString()}
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex items-center justify-end gap-2">
                      <a
                        href={`/admin/users?edit=${u.id}`}
                        class="inline-flex items-center gap-1 rounded-lg border border-[var(--border)] bg-[var(--surface-hover)] px-2.5 py-1.5 text-xs font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors"
                      >
                        Edit
                      </a>
                      {u.id !== adminUser.id && (
                        <form method="POST" onsubmit="return confirm('Delete this user? This cannot be undone.')">
                          <input type="hidden" name="_action" value="delete" />
                          <input type="hidden" name="userId" value={u.id} />
                          <button
                            type="submit"
                            class="inline-flex items-center gap-1 rounded-lg border border-red-200 px-2.5 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 hover:border-red-300 transition-colors"
                          >
                            Delete
                          </button>
                        </form>
                      )}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    {totalPages > 1 && (
      <div class="flex items-center justify-between text-sm text-[var(--text-muted)]">
        <span>{filteredUsers.length} result{filteredUsers.length !== 1 ? 's' : ''}</span>
        <div class="flex items-center gap-2">
          {currentPage > 0 ? (
            <a href={`/admin/users?q=${searchQ}&page=${currentPage - 1}`} class="px-3 py-1.5 rounded-lg border border-[var(--border)] hover:bg-[var(--surface-hover)] transition-colors">← Prev</a>
          ) : (
            <span class="px-3 py-1.5 rounded-lg border border-[var(--border)] opacity-40">← Prev</span>
          )}
          <span>{currentPage + 1} / {totalPages}</span>
          {currentPage < totalPages - 1 ? (
            <a href={`/admin/users?q=${searchQ}&page=${currentPage + 1}`} class="px-3 py-1.5 rounded-lg border border-[var(--border)] hover:bg-[var(--surface-hover)] transition-colors">Next →</a>
          ) : (
            <span class="px-3 py-1.5 rounded-lg border border-[var(--border)] opacity-40">Next →</span>
          )}
        </div>
      </div>
    )}

  </div>
</AdminLayout>
