---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { db, users, passwordResetTokens } from '@/db';
import { eq } from 'drizzle-orm';
import bcrypt from 'bcryptjs';

const token = Astro.url.searchParams.get('token');
let message = '';
let error = '';
let resetLink = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('_action') ?? '');

  if (action === 'request') {
    const email = String(form.get('email') ?? '').trim().toLowerCase();
    if (!email) {
      error = 'Email is required.';
    } else {
      // Check if user exists
      const [user] = await db.select().from(users).where(eq(users.email, email)).limit(1);
      
      if (user) {
        // Generate token
        const resetToken = crypto.randomUUID();
        const expiresAt = new Date(Date.now() + 60 * 60 * 1000); // 1 hour

        // Delete any existing tokens for this user
        await db.delete(passwordResetTokens).where(eq(passwordResetTokens.userId, user.id));

        // Create new token
        await db.insert(passwordResetTokens).values({
          token: resetToken,
          userId: user.id,
          expiresAt,
        });

        // Generate reset link
        resetLink = `${Astro.url.origin}/admin/password-reset?token=${resetToken}`;
        message = 'Password reset link generated (valid for 1 hour):';
      } else {
        // Don't reveal that the user doesn't exist for security
        message = 'If an account exists with that email, a reset link has been generated.';
      }
    }
  } else if (action === 'reset') {
    const newPassword = String(form.get('password') ?? '');
    const confirmPassword = String(form.get('confirmPassword') ?? '');

    if (!token) {
      error = 'Invalid or missing token.';
    } else if (!newPassword || newPassword.length < 8) {
      error = 'Password must be at least 8 characters.';
    } else if (newPassword !== confirmPassword) {
      error = 'Passwords do not match.';
    } else {
      // Verify token
      const [resetToken] = await db
        .select()
        .from(passwordResetTokens)
        .where(eq(passwordResetTokens.token, token))
        .limit(1);

      if (!resetToken) {
        error = 'Invalid or expired reset token.';
      } else if (resetToken.expiresAt < new Date()) {
        error = 'This reset token has expired. Please request a new one.';
        await db.delete(passwordResetTokens).where(eq(passwordResetTokens.token, token));
      } else {
        // Update password
        const passwordHash = await bcrypt.hash(newPassword, 12);
        await db.update(users).set({ passwordHash }).where(eq(users.id, resetToken.userId));

        // Update accounts table
        const { accounts } = await import('@/db');
        await db.update(accounts).set({ password: passwordHash }).where(eq(accounts.userId, resetToken.userId));

        // Delete used token
        await db.delete(passwordResetTokens).where(eq(passwordResetTokens.token, token));

        message = 'Password reset successfully! You can now log in.';
      }
    }
  }
}

// If token provided in URL, validate it
let validToken = false;
if (token && !message && !error) {
  const [resetToken] = await db
    .select()
    .from(passwordResetTokens)
    .where(eq(passwordResetTokens.token, token))
    .limit(1);
  
  if (resetToken && resetToken.expiresAt > new Date()) {
    validToken = true;
  } else if (resetToken) {
    error = 'This reset token has expired. Please request a new one.';
  } else {
    error = 'Invalid reset token.';
  }
}
---

<BaseLayout title="Password Reset">
  <div class="min-h-screen flex items-center justify-center px-4 py-12 bg-[var(--background)]">
    <div class="w-full max-w-md">
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-8">
        <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-6 text-center">
          {validToken ? 'Reset Your Password' : 'Forgot Password?'}
        </h1>

        {message && (
          <div class="mb-5 flex items-center gap-2.5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <span>{message}</span>
          </div>
        )}

        {error && (
          <div class="mb-5 flex items-center gap-2.5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
            </svg>
            <span>{error}</span>
          </div>
        )}

        {resetLink && (
          <div class="mb-5 p-4 rounded-xl border border-blue-200 bg-blue-50">
            <p class="text-sm font-medium text-blue-700 mb-2">Reset Link:</p>
            <div class="flex items-center gap-2">
              <input
                type="text"
                readonly
                value={resetLink}
                class="flex-1 rounded-lg border border-blue-300 bg-white px-3 py-2 text-sm text-blue-900 font-mono text-xs"
                onclick="this.select()"
              />
              <button
                onclick={`navigator.clipboard.writeText('${resetLink}'); this.textContent='✓';setTimeout(()=>this.textContent='Copy',2000)`}
                class="px-3 py-2 text-sm font-medium text-blue-700 hover:text-blue-800 transition-colors"
              >
                Copy
              </button>
            </div>
            <p class="text-xs text-blue-600 mt-2">This link expires in 1 hour. Copy and share it securely with the user.</p>
          </div>
        )}

        {validToken ? (
          <!-- Reset Password Form -->
          <form method="POST" class="space-y-4">
            <input type="hidden" name="_action" value="reset" />
            
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">
                New Password <span class="text-red-500">*</span>
              </label>
              <input
                type="password"
                name="password"
                required
                minlength={8}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Min 8 characters"
              />
            </div>

            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">
                Confirm Password <span class="text-red-500">*</span>
              </label>
              <input
                type="password"
                name="confirmPassword"
                required
                minlength={8}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Re-enter password"
              />
            </div>

            <button
              type="submit"
              class="w-full rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
            >
              Reset Password
            </button>

            <div class="text-center pt-2">
              <a href="/admin/login" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">
                Back to Login
              </a>
            </div>
          </form>
        ) : (
          <!-- Request Reset Form -->
          <form method="POST" class="space-y-4">
            <input type="hidden" name="_action" value="request" />
            
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">
                Email Address <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                name="email"
                required
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="admin@example.com"
              />
              <p class="text-xs text-[var(--text-muted)] mt-1.5">
                Enter your email to generate a password reset link.
              </p>
            </div>

            <button
              type="submit"
              class="w-full rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
            >
              Generate Reset Link
            </button>

            <div class="text-center pt-2">
              <a href="/admin/login" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">
                Back to Login
              </a>
            </div>
          </form>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
