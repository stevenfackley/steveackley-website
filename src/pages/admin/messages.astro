---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db, messages, users } from '@/db';
import { eq, desc } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/admin/login');

// Fetch all messages sent to the admin user, joined with sender info
const inbox = await db
  .select({
    id: messages.id,
    subject: messages.subject,
    body: messages.body,
    type: messages.type,
    read: messages.read,
    createdAt: messages.createdAt,
    fromName: users.name,
    fromEmail: users.email,
    fromCompany: users.companyName,
  })
  .from(messages)
  .innerJoin(users, eq(messages.fromUserId, users.id))
  .where(eq(messages.toUserId, user.id))
  .orderBy(desc(messages.createdAt));

function timeAgo(date: Date): string {
  const seconds = Math.floor((Date.now() - date.getTime()) / 1000);
  if (seconds < 60) return 'just now';
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes}m ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  if (days < 30) return `${days}d ago`;
  return date.toLocaleDateString();
}
---

<AdminLayout title="Messages">
  <div class="space-y-6">

    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-[var(--text-primary)]">Messages</h1>
        <p class="text-[var(--text-secondary)] mt-1.5">
          {inbox.length === 0
            ? 'No messages yet'
            : `${inbox.filter(m => !m.read).length} unread of ${inbox.length} total`}
        </p>
      </div>
    </div>

    {inbox.length === 0 ? (
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-12 flex flex-col items-center text-center gap-3">
        <div class="h-12 w-12 rounded-full bg-[var(--surface-hover)] flex items-center justify-center">
          <svg class="h-6 w-6 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <p class="text-sm font-medium text-[var(--text-primary)]">Your inbox is empty</p>
        <p class="text-xs text-[var(--text-muted)]">Messages from clients will appear here.</p>
      </div>
    ) : (
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl overflow-hidden divide-y divide-[var(--border)]">
        {inbox.map((msg) => (
          <details class="group">
            <summary class={`flex items-start gap-4 px-5 py-4 cursor-pointer hover:bg-[var(--surface-hover)] transition-colors list-none ${!msg.read ? 'bg-blue-50/40 dark:bg-blue-950/20' : ''}`}>
              <!-- Unread dot -->
              <div class="mt-1 h-2 w-2 shrink-0 rounded-full transition-colors" style={!msg.read ? 'background:var(--accent)' : 'background:transparent;border:1px solid var(--border)'} />

              <!-- Avatar -->
              <div class="shrink-0 h-9 w-9 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-xs font-bold uppercase">
                {(msg.fromName || msg.fromEmail || '?').charAt(0)}
              </div>

              <!-- Info -->
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between gap-2">
                  <span class={`text-sm truncate ${!msg.read ? 'font-bold text-[var(--text-primary)]' : 'font-medium text-[var(--text-secondary)]'}`}>
                    {msg.fromName || msg.fromEmail}
                  </span>
                  <span class="text-xs text-[var(--text-muted)] shrink-0">{timeAgo(msg.createdAt)}</span>
                </div>
                <p class={`text-sm truncate ${!msg.read ? 'font-semibold text-[var(--text-primary)]' : 'text-[var(--text-secondary)]'}`}>
                  {msg.subject}
                </p>
                <p class="text-xs text-[var(--text-muted)] truncate mt-0.5">{msg.body.substring(0, 100)}</p>
              </div>

              <!-- Type badge + chevron -->
              <div class="flex items-center gap-2 shrink-0">
                {msg.type === 'PROJECT_REQUEST' && (
                  <span class="inline-flex items-center rounded-full bg-violet-100 dark:bg-violet-950 px-2 py-0.5 text-xs font-semibold text-violet-700 dark:text-violet-300">
                    Project
                  </span>
                )}
                <svg class="h-4 w-4 text-[var(--text-muted)] group-open:rotate-90 transition-transform" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                </svg>
              </div>
            </summary>

            <!-- Expanded body -->
            <div class="px-5 pb-5 pt-3 bg-[var(--background)] border-t border-[var(--border)]">
              <div class="flex items-center justify-between mb-3">
                <div class="text-xs text-[var(--text-muted)] space-y-0.5">
                  <p><span class="font-medium text-[var(--text-secondary)]">From:</span> {msg.fromName ? `${msg.fromName} <${msg.fromEmail}>` : msg.fromEmail}</p>
                  {msg.fromCompany && <p><span class="font-medium text-[var(--text-secondary)]">Company:</span> {msg.fromCompany}</p>}
                  <p><span class="font-medium text-[var(--text-secondary)]">Subject:</span> {msg.subject}</p>
                  <p><span class="font-medium text-[var(--text-secondary)]">Received:</span> {msg.createdAt.toLocaleString()}</p>
                </div>
              </div>
              <div class="rounded-xl border border-[var(--border)] bg-[var(--surface)] px-4 py-3 text-sm text-[var(--text-primary)] whitespace-pre-wrap leading-relaxed">
                {msg.body}
              </div>
              <div class="mt-3 flex gap-2">
                <a
                  href={`mailto:${msg.fromEmail}?subject=Re: ${encodeURIComponent(msg.subject)}`}
                  class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--border)] px-3 py-1.5 text-xs font-semibold text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] transition-colors"
                >
                  <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path d="M3 4a2 2 0 00-2 2v1.161l8.441 4.221a1.25 1.25 0 001.118 0L19 7.162V6a2 2 0 00-2-2H3z" /><path d="M19 8.839l-7.77 3.885a2.75 2.75 0 01-2.46 0L1 8.839V14a2 2 0 002 2h14a2 2 0 002-2V8.839z" /></svg>
                  Reply via email
                </a>
              </div>
            </div>
          </details>
        ))}
      </div>
    )}

  </div>
</AdminLayout>
