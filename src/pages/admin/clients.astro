---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { db, users, clientApps, userApps } from '@/db';
import { eq, desc, and } from 'drizzle-orm';
import bcrypt from 'bcryptjs';

const adminUser = Astro.locals.user;
if (!adminUser) return Astro.redirect('/admin/login');

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('_action') ?? '');

  try {
    if (action === 'create') {
      const email = String(form.get('email') ?? '').trim().toLowerCase();
      const name = String(form.get('name') ?? '').trim();
      const password = String(form.get('password') ?? '');
      const companyName = String(form.get('companyName') ?? '').trim();
      const contactFirstName = String(form.get('contactFirstName') ?? '').trim();
      const contactLastName = String(form.get('contactLastName') ?? '').trim();

      if (!email || !password) throw new Error('Email and password are required.');
      if (password.length < 8) throw new Error('Password must be at least 8 characters.');

      const existing = await db.select({ id: users.id }).from(users).where(eq(users.email, email)).limit(1);
      if (existing.length > 0) throw new Error('A user with that email already exists.');

      const passwordHash = await bcrypt.hash(password, 12);
      const userId = crypto.randomUUID();

      await db.insert(users).values({
        id: userId,
        email,
        name: name || null,
        passwordHash,
        role: 'CLIENT',
        companyName: companyName || null,
        contactFirstName: contactFirstName || null,
        contactLastName: contactLastName || null,
        emailVerified: false,
      });

      const { accounts } = await import('@/db');
      await db.insert(accounts).values({
        id: crypto.randomUUID(),
        accountId: userId,
        providerId: 'credential',
        userId,
        password: passwordHash,
        createdAt: new Date(),
        updatedAt: new Date(),
      });

      successMessage = `Client "${email}" created successfully.`;

    } else if (action === 'update') {
      const userId = String(form.get('userId') ?? '');
      const name = String(form.get('name') ?? '').trim();
      const companyName = String(form.get('companyName') ?? '').trim();
      const contactFirstName = String(form.get('contactFirstName') ?? '').trim();
      const contactLastName = String(form.get('contactLastName') ?? '').trim();
      const newPassword = String(form.get('newPassword') ?? '');

      if (!userId) throw new Error('Client ID is required.');

      if (newPassword) {
        if (newPassword.length < 8) throw new Error('Password must be at least 8 characters.');
        const passwordHash = await bcrypt.hash(newPassword, 12);
        const { accounts } = await import('@/db');
        await db.update(accounts).set({ password: passwordHash }).where(eq(accounts.userId, userId));
        await db.update(users).set({
          name: name || null,
          companyName: companyName || null,
          contactFirstName: contactFirstName || null,
          contactLastName: contactLastName || null,
          passwordHash,
        }).where(eq(users.id, userId));
      } else {
        await db.update(users).set({
          name: name || null,
          companyName: companyName || null,
          contactFirstName: contactFirstName || null,
          contactLastName: contactLastName || null,
        }).where(eq(users.id, userId));
      }
      successMessage = 'Client updated successfully.';

    } else if (action === 'delete') {
      const userId = String(form.get('userId') ?? '');
      if (!userId) throw new Error('Client ID is required.');
      if (userId === adminUser.id) throw new Error('You cannot delete your own account.');
      await db.delete(users).where(eq(users.id, userId));
      successMessage = 'Client deleted.';

    } else if (action === 'assign') {
      const userId = String(form.get('userId') ?? '');
      const appId = String(form.get('appId') ?? '');
      if (!userId || !appId) throw new Error('Client ID and App ID are required.');
      await db.insert(userApps).values({ userId, appId }).onConflictDoNothing();
      successMessage = 'App assigned to client.';

    } else if (action === 'unassign') {
      const userId = String(form.get('userId') ?? '');
      const appId = String(form.get('appId') ?? '');
      if (!userId || !appId) throw new Error('Client ID and App ID are required.');
      await db.delete(userApps).where(and(eq(userApps.userId, userId), eq(userApps.appId, appId)));
      successMessage = 'App removed from client.';
    }
  } catch (e) {
    errorMessage = e instanceof Error ? e.message : 'An error occurred.';
  }
}

// Fetch all CLIENT-role users
const allClients = await db
  .select()
  .from(users)
  .where(eq(users.role, 'CLIENT'))
  .orderBy(desc(users.createdAt));

// Fetch all apps
const allApps = await db.select().from(clientApps).orderBy(clientApps.name);

// Fetch all assignments
const assignments = await db
  .select({ userId: userApps.userId, appId: userApps.appId })
  .from(userApps);

// Group assignments by userId
const appsByClient: Record<string, Set<string>> = {};
for (const a of assignments) {
  if (!appsByClient[a.userId]) appsByClient[a.userId] = new Set();
  appsByClient[a.userId].add(a.appId);
}

// Build a lookup for apps by id
const appsById = Object.fromEntries(allApps.map(a => [a.id, a]));

const editClientId = Astro.url.searchParams.get('edit');
const editClient = editClientId ? allClients.find(c => c.id === editClientId) : null;

const searchQ = (Astro.url.searchParams.get('q') ?? '').toLowerCase();
const filteredClients = searchQ
  ? allClients.filter(c =>
      (c.email ?? '').toLowerCase().includes(searchQ) ||
      (c.name ?? '').toLowerCase().includes(searchQ) ||
      (c.companyName ?? '').toLowerCase().includes(searchQ) ||
      (c.contactFirstName ?? '').toLowerCase().includes(searchQ) ||
      (c.contactLastName ?? '').toLowerCase().includes(searchQ)
    )
  : allClients;

const PAGE_SIZE = 20;
const currentPage = Math.max(0, parseInt(Astro.url.searchParams.get('page') ?? '0'));
const totalPages = Math.ceil(filteredClients.length / PAGE_SIZE);
const pagedClients = filteredClients.slice(currentPage * PAGE_SIZE, (currentPage + 1) * PAGE_SIZE);

const envColors: Record<string, string> = {
  PRODUCTION: 'bg-emerald-100 text-emerald-700',
  TEST: 'bg-amber-100 text-amber-700',
  DEVELOPMENT: 'bg-blue-100 text-blue-700',
};

// Pre-compute per-client display data to avoid block-body arrow functions in template
const clientRows = pagedClients.map((client) => {
  const assignedAppIds = appsByClient[client.id] ?? new Set<string>();
  const assignedApps = [...assignedAppIds].map(id => appsById[id]).filter(Boolean);
  const unassignedApps = allApps.filter(a => !assignedAppIds.has(a.id));
  const displayName = client.companyName || client.name || client.email;
  const initials = displayName.charAt(0).toUpperCase();
  return { client, assignedApps, unassignedApps, displayName, initials };
});
---

<AdminLayout title="Clients">
  <div class="space-y-6">

    <!-- Page header -->
    <div class="flex items-center justify-between flex-wrap gap-3">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-[var(--text-primary)]">Clients</h1>
        <p class="text-[var(--text-secondary)] mt-1.5">
          {filteredClients.length} of {allClients.length} client{allClients.length !== 1 ? 's' : ''}
        </p>
      </div>
      <a
        href="?create=1"
        class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        New Client
      </a>
    </div>

    <!-- Flash messages -->
    {successMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
        </svg>
        {successMessage}
      </div>
    )}
    {errorMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
        </svg>
        {errorMessage}
      </div>
    )}

    <!-- Create / Edit Form -->
    {(Astro.url.searchParams.has('create') || editClient) && (
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-6">
        <h2 class="text-lg font-bold text-[var(--text-primary)] mb-5">
          {editClient
            ? `Edit Client: ${editClient.companyName || editClient.name || editClient.email}`
            : 'Create New Client'}
        </h2>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="_action" value={editClient ? 'update' : 'create'} />
          {editClient && <input type="hidden" name="userId" value={editClient.id} />}

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Email (create only) -->
            {!editClient && (
              <div>
                <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  name="email"
                  required
                  class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                  placeholder="client@company.com"
                />
              </div>
            )}
            {editClient && (
              <div>
                <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Email</label>
                <input
                  type="email"
                  value={editClient.email}
                  disabled
                  class="w-full rounded-xl border border-[var(--border)] bg-[var(--surface-hover)] px-3 py-2.5 text-sm text-[var(--text-muted)] cursor-not-allowed"
                />
              </div>
            )}

            <!-- Password -->
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">
                {editClient ? 'New Password (leave blank to keep)' : 'Password *'}
              </label>
              <input
                type="password"
                name={editClient ? 'newPassword' : 'password'}
                required={!editClient}
                minlength={8}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Min 8 characters"
              />
            </div>

            <!-- Company Name -->
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Company Name</label>
              <input
                type="text"
                name="companyName"
                value={editClient?.companyName ?? ''}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Acme Corp"
              />
            </div>

            <!-- Display Name -->
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Display Name</label>
              <input
                type="text"
                name="name"
                value={editClient?.name ?? ''}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Jane Smith"
              />
            </div>

            <!-- Contact First Name -->
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Contact First Name</label>
              <input
                type="text"
                name="contactFirstName"
                value={editClient?.contactFirstName ?? ''}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Jane"
              />
            </div>

            <!-- Contact Last Name -->
            <div>
              <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Contact Last Name</label>
              <input
                type="text"
                name="contactLastName"
                value={editClient?.contactLastName ?? ''}
                class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
                placeholder="Smith"
              />
            </div>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <button
              type="submit"
              class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
            >
              {editClient ? 'Save Changes' : 'Create Client'}
            </button>
            <a href="/admin/clients" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors">
              Cancel
            </a>
          </div>
        </form>
      </div>
    )}

    <!-- Search -->
    <form method="GET" class="flex items-center gap-2">
      <input
        type="search"
        name="q"
        value={searchQ}
        placeholder="Search clients…"
        class="w-full max-w-sm rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
      />
      <button type="submit" class="rounded-xl border border-[var(--border)] bg-[var(--surface-hover)] px-3 py-2 text-sm text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Search</button>
      {searchQ && <a href="/admin/clients" class="text-sm text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors">Clear</a>}
    </form>

    <!-- Clients list -->
    {allClients.length === 0 ? (
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-12 flex flex-col items-center text-center gap-3">
        <div class="h-14 w-14 rounded-full bg-[var(--surface-hover)] flex items-center justify-center">
          <svg class="h-7 w-7 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
        </div>
        <p class="text-sm font-bold text-[var(--text-primary)]">No clients yet</p>
        <p class="text-xs text-[var(--text-muted)]">Click "New Client" to add your first client.</p>
        <a
          href="?create=1"
          class="mt-2 inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          New Client
        </a>
      </div>
    ) : (
      <div class="space-y-4">
        {clientRows.map(({ client, assignedApps, unassignedApps, displayName, initials }) => (
            <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl overflow-hidden">
              <!-- Client header row -->
              <div class="flex items-center gap-4 px-5 py-4">
                <!-- Avatar -->
                <div class="h-11 w-11 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-base font-bold shrink-0">
                  {initials}
                </div>

                <!-- Info -->
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-[var(--text-primary)] truncate">{displayName}</p>
                  <p class="text-xs text-[var(--text-muted)] truncate">{client.email}</p>
                  {(client.contactFirstName || client.contactLastName) && (
                    <p class="text-xs text-[var(--text-secondary)] mt-0.5">
                      Contact: {[client.contactFirstName, client.contactLastName].filter(Boolean).join(' ')}
                    </p>
                  )}
                </div>

                <!-- Joined date -->
                <p class="text-xs text-[var(--text-muted)] hidden sm:block shrink-0">
                  Joined {client.createdAt.toLocaleDateString()}
                </p>

                <!-- Actions -->
                <div class="flex items-center gap-2 shrink-0">
                  <a
                    href={`/admin/clients?edit=${client.id}`}
                    class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--border)] bg-[var(--surface-hover)] px-3 py-1.5 text-xs font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors"
                  >
                    Edit
                  </a>
                  <form method="POST" onsubmit="return confirm('Delete this client? This cannot be undone.')">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="userId" value={client.id} />
                    <button
                      type="submit"
                      class="inline-flex items-center gap-1.5 rounded-lg border border-red-200 px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 hover:border-red-300 transition-colors"
                    >
                      Delete
                    </button>
                  </form>
                </div>
              </div>

              <!-- Apps section -->
              <div class="border-t border-[var(--border)] px-5 py-4 bg-[var(--surface-hover)] bg-opacity-50">
                <div class="flex items-center justify-between mb-3">
                  <p class="text-xs font-semibold text-[var(--text-muted)] uppercase tracking-wide">
                    Assigned Apps ({assignedApps.length})
                  </p>
                </div>

                <!-- Assigned app chips -->
                {assignedApps.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-3">
                    {assignedApps.map((app) => (
                        <span class="inline-flex items-center gap-2 rounded-xl border border-[var(--border)] bg-[var(--surface)] px-3 py-1.5 text-xs">
                          <span class="font-medium text-[var(--text-primary)]">{app.productName || app.name}</span>
                          <span class={`rounded-full px-1.5 py-0.5 font-semibold ${envColors[app.environment] ?? envColors['PRODUCTION']}`}>
                            {app.environment}
                          </span>
                          <!-- Unassign button -->
                          <form method="POST" class="inline leading-none">
                            <input type="hidden" name="_action" value="unassign" />
                            <input type="hidden" name="userId" value={client.id} />
                            <input type="hidden" name="appId" value={app.id} />
                            <button
                              type="submit"
                              class="text-[var(--text-muted)] hover:text-red-500 transition-colors"
                              title={`Remove ${app.productName || app.name}`}
                            >
                              <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
                              </svg>
                            </button>
                          </form>
                        </span>
                    ))}
                  </div>
                )}

                <!-- Assign new app -->
                {unassignedApps.length > 0 && (
                  <form method="POST" class="flex items-center gap-2">
                    <input type="hidden" name="_action" value="assign" />
                    <input type="hidden" name="userId" value={client.id} />
                    <select
                      name="appId"
                      class="flex-1 rounded-lg border border-[var(--border)] bg-[var(--background)] px-2.5 py-1.5 text-xs text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none transition-colors"
                    >
                      <option value="">Add an app…</option>
                      {unassignedApps.map((a) => (
                        <option value={a.id}>{a.productName || a.name}{a.companyName ? ` (${a.companyName})` : ''}</option>
                      ))}
                    </select>
                    <button
                      type="submit"
                      class="shrink-0 rounded-lg border border-[var(--border)] bg-[var(--background)] px-3 py-1.5 text-xs font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors"
                    >
                      Assign
                    </button>
                  </form>
                )}
                {unassignedApps.length === 0 && allApps.length === 0 && (
                  <p class="text-xs text-[var(--text-muted)] italic">
                    No apps exist yet. <a href="/admin/apps?create=1" class="text-[var(--accent)] hover:underline">Create an app</a> first.
                  </p>
                )}
                {unassignedApps.length === 0 && allApps.length > 0 && (
                  <p class="text-xs text-[var(--text-muted)] italic">All apps are already assigned to this client.</p>
                )}
              </div>
            </div>
        ))}
      </div>
    )}

    {totalPages > 1 && (
      <div class="flex items-center justify-between text-sm text-[var(--text-muted)]">
        <span>{filteredClients.length} result{filteredClients.length !== 1 ? 's' : ''}</span>
        <div class="flex items-center gap-2">
          {currentPage > 0 ? (
            <a href={`/admin/clients?q=${searchQ}&page=${currentPage - 1}`} class="px-3 py-1.5 rounded-lg border border-[var(--border)] hover:bg-[var(--surface-hover)] transition-colors">← Prev</a>
          ) : (
            <span class="px-3 py-1.5 rounded-lg border border-[var(--border)] opacity-40">← Prev</span>
          )}
          <span>{currentPage + 1} / {totalPages}</span>
          {currentPage < totalPages - 1 ? (
            <a href={`/admin/clients?q=${searchQ}&page=${currentPage + 1}`} class="px-3 py-1.5 rounded-lg border border-[var(--border)] hover:bg-[var(--surface-hover)] transition-colors">Next →</a>
          ) : (
            <span class="px-3 py-1.5 rounded-lg border border-[var(--border)] opacity-40">Next →</span>
          )}
        </div>
      </div>
    )}

  </div>
</AdminLayout>
