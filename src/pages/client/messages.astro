---
import ClientLayout from '@/layouts/ClientLayout.astro';
import { db, users, messages } from '@/db';
import { eq, desc, and } from 'drizzle-orm';

const sessionUser = Astro.locals.user;
if (!sessionUser) return Astro.redirect('/client/login');

// Handle mark-as-read
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('_action') ?? '');
  if (action === 'mark-read') {
    const msgId = String(form.get('messageId') ?? '');
    if (msgId) {
      await db.update(messages).set({ read: true }).where(
        and(eq(messages.id, msgId), eq(messages.toUserId, sessionUser.id))
      );
    }
  } else if (action === 'mark-all-read') {
    await db.update(messages).set({ read: true }).where(
      and(eq(messages.toUserId, sessionUser.id), eq(messages.read, false))
    );
  }
}

// Fetch messages for this user, newest first, with sender info
const inbox = await db
  .select({
    id: messages.id,
    subject: messages.subject,
    body: messages.body,
    type: messages.type,
    read: messages.read,
    createdAt: messages.createdAt,
    fromName: users.name,
    fromEmail: users.email,
  })
  .from(messages)
  .innerJoin(users, eq(messages.fromUserId, users.id))
  .where(eq(messages.toUserId, sessionUser.id))
  .orderBy(desc(messages.createdAt));

const unreadCount = inbox.filter(m => !m.read).length;
---

<ClientLayout title="Messages">
  <div class="space-y-6">

    <div class="flex items-center justify-between flex-wrap gap-3">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-[var(--text-primary)]">Messages</h1>
        <p class="text-[var(--text-secondary)] mt-1.5">
          {inbox.length === 0 ? 'No messages yet' : `${inbox.length} message${inbox.length !== 1 ? 's' : ''}${unreadCount > 0 ? `, ${unreadCount} unread` : ''}`}
        </p>
      </div>
      {unreadCount > 0 && (
        <form method="POST">
          <input type="hidden" name="_action" value="mark-all-read" />
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-xl border border-[var(--border)] bg-[var(--surface-hover)] px-4 py-2 text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors"
          >
            Mark all as read
          </button>
        </form>
      )}
    </div>

    {inbox.length === 0 ? (
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-12 text-center">
        <div class="h-12 w-12 rounded-full bg-[var(--surface-hover)] flex items-center justify-center mx-auto mb-3">
          <svg class="h-6 w-6 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <p class="text-sm font-medium text-[var(--text-primary)]">No messages yet</p>
        <p class="text-xs text-[var(--text-muted)] mt-1">Messages from your account manager will appear here.</p>
      </div>
    ) : (
      <div class="space-y-3">
        {inbox.map((msg) => (
          <details
            class:list={[
              'group bg-[var(--surface)] border rounded-2xl overflow-hidden transition-colors',
              msg.read ? 'border-[var(--border)]' : 'border-[var(--accent)]/40 bg-blue-50/30',
            ]}
          >
            <summary class="flex items-start gap-4 px-5 py-4 cursor-pointer list-none select-none">
              <!-- Unread dot -->
              <div class="shrink-0 mt-1">
                {!msg.read ? (
                  <div class="h-2.5 w-2.5 rounded-full bg-blue-500" title="Unread"></div>
                ) : (
                  <div class="h-2.5 w-2.5 rounded-full bg-[var(--border)]"></div>
                )}
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2 flex-wrap">
                  <div>
                    <p class:list={['text-sm', msg.read ? 'font-medium text-[var(--text-primary)]' : 'font-bold text-[var(--text-primary)]']}>
                      {msg.subject}
                    </p>
                    <p class="text-xs text-[var(--text-muted)] mt-0.5">
                      From {msg.fromName || msg.fromEmail}
                    </p>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    {msg.type === 'PROJECT_REQUEST' && (
                      <span class="inline-flex items-center rounded-full bg-purple-100 px-2 py-0.5 text-xs font-semibold text-purple-700">Project</span>
                    )}
                    <time class="text-xs text-[var(--text-muted)] whitespace-nowrap">
                      {msg.createdAt.toLocaleDateString()}
                    </time>
                  </div>
                </div>
                <p class="text-xs text-[var(--text-muted)] mt-1 line-clamp-1 group-open:hidden">
                  {msg.body.substring(0, 120)}{msg.body.length > 120 ? '…' : ''}
                </p>
              </div>

              <svg class="h-4 w-4 text-[var(--text-muted)] shrink-0 mt-0.5 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>

            <!-- Message body -->
            <div class="px-5 pb-5 pt-2 border-t border-[var(--border)]">
              <p class="text-sm text-[var(--text-secondary)] whitespace-pre-wrap leading-relaxed">{msg.body}</p>

              <div class="flex items-center gap-3 mt-4 pt-4 border-t border-[var(--border)]">
                <a
                  href={`mailto:${msg.fromEmail}?subject=Re: ${encodeURIComponent(msg.subject)}`}
                  class="inline-flex items-center gap-1.5 rounded-lg bg-[var(--surface-hover)] border border-[var(--border)] px-3 py-1.5 text-xs font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-colors"
                >
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
                  </svg>
                  Reply via Email
                </a>
                {!msg.read && (
                  <form method="POST" class="inline">
                    <input type="hidden" name="_action" value="mark-read" />
                    <input type="hidden" name="messageId" value={msg.id} />
                    <button
                      type="submit"
                      class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--border)] px-3 py-1.5 text-xs font-medium text-[var(--text-muted)] hover:text-[var(--text-secondary)] transition-colors"
                    >
                      Mark as read
                    </button>
                  </form>
                )}
              </div>
            </div>
          </details>
        ))}
      </div>
    )}
  </div>
</ClientLayout>
