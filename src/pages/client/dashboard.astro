---
import ClientLayout from '@/layouts/ClientLayout.astro';
import { db, users, userApps, clientApps, messages } from '@/db';
import { eq, desc, and } from 'drizzle-orm';

const sessionUser = Astro.locals.user;
if (!sessionUser) return Astro.redirect('/client/login');

// Re-fetch full user profile
const [currentUser] = await db.select().from(users).where(eq(users.id, sessionUser.id)).limit(1);
if (!currentUser) return Astro.redirect('/client/login');

// Fetch assigned apps
const assignedApps = await db
  .select({ app: clientApps })
  .from(userApps)
  .innerJoin(clientApps, eq(userApps.appId, clientApps.id))
  .where(eq(userApps.userId, currentUser.id));

// Unread messages count
const unreadMessages = await db
  .select({ id: messages.id })
  .from(messages)
  .where(and(eq(messages.toUserId, currentUser.id), eq(messages.read, false)));

const displayName = currentUser.name || currentUser.contactFirstName || currentUser.email.split('@')[0];
const companyDisplay = currentUser.companyName ? ` — ${currentUser.companyName}` : '';

const envColors: Record<string, string> = {
  PRODUCTION: 'bg-emerald-100 text-emerald-700',
  TEST: 'bg-amber-100 text-amber-700',
  DEVELOPMENT: 'bg-blue-100 text-blue-700',
};
---

<ClientLayout title="Dashboard">
  <div class="space-y-8">

    <!-- Welcome header -->
    <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-6 text-white">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-2xl font-extrabold tracking-tight">
            Welcome back, {displayName}!
          </h1>
          <p class="text-blue-100/80 mt-1 text-sm">{companyDisplay || 'Client Portal'}</p>
        </div>
        {unreadMessages.length > 0 && (
          <a
            href="/client/messages"
            class="shrink-0 inline-flex items-center gap-2 rounded-xl bg-white/15 hover:bg-white/25 backdrop-blur-sm px-3 py-2 text-sm font-medium text-white transition-colors border border-white/20"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            {unreadMessages.length} new message{unreadMessages.length !== 1 ? 's' : ''}
          </a>
        )}
      </div>
      <div class="mt-4 grid grid-cols-2 sm:grid-cols-3 gap-3 text-center">
        <div class="bg-white/10 rounded-xl p-3">
          <p class="text-2xl font-bold">{assignedApps.length}</p>
          <p class="text-xs text-blue-100/70 mt-0.5">Active App{assignedApps.length !== 1 ? 's' : ''}</p>
        </div>
        <div class="bg-white/10 rounded-xl p-3">
          <p class="text-2xl font-bold">{unreadMessages.length}</p>
          <p class="text-xs text-blue-100/70 mt-0.5">Unread Message{unreadMessages.length !== 1 ? 's' : ''}</p>
        </div>
      </div>
    </div>

    <!-- Your Apps -->
    <div>
      <h2 class="text-lg font-bold text-[var(--text-primary)] mb-4">Your Applications</h2>

      {assignedApps.length === 0 ? (
        <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-10 text-center">
          <div class="h-12 w-12 rounded-full bg-[var(--surface-hover)] flex items-center justify-center mx-auto mb-3">
            <svg class="h-6 w-6 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
            </svg>
          </div>
          <p class="text-sm font-medium text-[var(--text-primary)]">No apps assigned yet</p>
          <p class="text-xs text-[var(--text-muted)] mt-1">Your applications will appear here once configured.</p>
        </div>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {assignedApps.map(({ app }) => {
            const envClass = envColors[app.environment] ?? envColors['PRODUCTION'];
            return (
              <a
                href={app.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-[var(--surface)] border border-[var(--border)] hover:border-[var(--accent)] rounded-2xl p-5 flex flex-col gap-3 transition-all duration-200 hover:shadow-lg"
              >
                <div class="flex items-start justify-between gap-2">
                  <div class="flex items-center gap-3">
                    {app.favicon || app.icon ? (
                      <img src={app.favicon || app.icon || ''} alt={app.name} class="h-10 w-10 rounded-xl object-contain bg-[var(--surface-hover)] p-1 shrink-0" />
                    ) : (
                      <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-sm font-bold shrink-0">
                        {app.name.charAt(0).toUpperCase()}
                      </div>
                    )}
                    <div class="min-w-0">
                      <p class="font-bold text-sm text-[var(--text-primary)] truncate">{app.productName || app.name}</p>
                      {app.companyName && <p class="text-xs text-[var(--text-muted)] truncate">{app.companyName}</p>}
                    </div>
                  </div>
                  <span class={`shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold ${envClass}`}>
                    {app.environment}
                  </span>
                </div>

                {app.description && (
                  <p class="text-xs text-[var(--text-secondary)] line-clamp-2 leading-relaxed">{app.description}</p>
                )}

                <div class="flex items-center justify-between mt-auto pt-2 border-t border-[var(--border)]">
                  <span class="text-xs text-[var(--text-muted)] truncate">{app.url}</span>
                  <svg class="h-4 w-4 text-[var(--accent)] shrink-0 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                  </svg>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>

  </div>
</ClientLayout>
