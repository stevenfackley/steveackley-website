---
import ClientLayout from '@/layouts/ClientLayout.astro';
import { db, users } from '@/db';
import { eq } from 'drizzle-orm';

const sessionUser = Astro.locals.user;
if (!sessionUser) return Astro.redirect('/client/login');

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();
    const name = String(form.get('name') ?? '').trim();
    const contactFirstName = String(form.get('contactFirstName') ?? '').trim();
    const contactLastName = String(form.get('contactLastName') ?? '').trim();
    const companyName = String(form.get('companyName') ?? '').trim();

    await db.update(users).set({
      name: name || null,
      contactFirstName: contactFirstName || null,
      contactLastName: contactLastName || null,
      companyName: companyName || null,
    }).where(eq(users.id, sessionUser.id));

    successMessage = 'Profile updated successfully.';
  } catch {
    errorMessage = 'Failed to save changes.';
  }
}

const [currentUser] = await db.select().from(users).where(eq(users.id, sessionUser.id)).limit(1);
---

<ClientLayout title="My Account">
  <div class="max-w-2xl space-y-8">

    <div>
      <h1 class="text-3xl font-extrabold tracking-tight text-[var(--text-primary)]">My Account</h1>
      <p class="text-[var(--text-secondary)] mt-1.5">Manage your profile and preferences</p>
    </div>

    {successMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
        {successMessage}
      </div>
    )}
    {errorMessage && (
      <div class="flex items-center gap-2.5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
        {errorMessage}
      </div>
    )}

    <!-- Profile card -->
    <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-6">
      <div class="flex items-center gap-4 mb-6 pb-6 border-b border-[var(--border)]">
        <div class="h-16 w-16 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-xl font-bold shrink-0">
          {(currentUser?.name || currentUser?.contactFirstName || currentUser?.email || '?').charAt(0).toUpperCase()}
        </div>
        <div>
          <p class="font-bold text-[var(--text-primary)]">
            {currentUser?.name || [currentUser?.contactFirstName, currentUser?.contactLastName].filter(Boolean).join(' ') || 'Client User'}
          </p>
          <p class="text-sm text-[var(--text-muted)]">{currentUser?.email}</p>
          {currentUser?.companyName && (
            <p class="text-xs text-[var(--text-secondary)] mt-0.5">{currentUser.companyName}</p>
          )}
        </div>
      </div>

      <form method="POST" class="space-y-5">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Display Name</label>
            <input
              type="text"
              name="name"
              value={currentUser?.name ?? ''}
              class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
              placeholder="Jane Smith"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Company Name</label>
            <input
              type="text"
              name="companyName"
              value={currentUser?.companyName ?? ''}
              class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
              placeholder="Acme Corp"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">First Name</label>
            <input
              type="text"
              name="contactFirstName"
              value={currentUser?.contactFirstName ?? ''}
              class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
              placeholder="Jane"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Last Name</label>
            <input
              type="text"
              name="contactLastName"
              value={currentUser?.contactLastName ?? ''}
              class="w-full rounded-xl border border-[var(--border)] bg-[var(--background)] px-3 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent)] focus:outline-none focus:ring-1 focus:ring-[var(--accent)] transition-colors"
              placeholder="Smith"
            />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--text-secondary)] mb-1.5">Email Address</label>
          <input
            type="email"
            value={currentUser?.email ?? ''}
            disabled
            class="w-full rounded-xl border border-[var(--border)] bg-[var(--surface-hover)] px-3 py-2.5 text-sm text-[var(--text-muted)] cursor-not-allowed"
          />
          <p class="text-xs text-[var(--text-muted)] mt-1">Email cannot be changed here. Contact your account manager.</p>
        </div>
        <div class="pt-1">
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-5 py-2.5 text-sm font-bold text-white hover:bg-blue-700 transition-colors"
          >
            Save Changes
          </button>
        </div>
      </form>
    </div>

    <!-- Theme preferences -->
    <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-widest mb-4">Display Preferences</h2>
      <div>
        <p class="text-sm font-medium text-[var(--text-secondary)] mb-2">Theme</p>
        <div class="flex items-center gap-3">
          <button
            id="theme-light-btn"
            type="button"
            class="inline-flex items-center gap-2 rounded-xl border px-4 py-2.5 text-sm font-medium transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 text-amber-500">
              <path d="M10 2a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 2zM10 15a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 15zM10 7a3 3 0 100 6 3 3 0 000-6z"/>
            </svg>
            Light
          </button>
          <button
            id="theme-dark-btn"
            type="button"
            class="inline-flex items-center gap-2 rounded-xl border px-4 py-2.5 text-sm font-medium transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 text-indigo-400">
              <path fill-rule="evenodd" d="M7.455 2.004a.75.75 0 01.26.77 7 7 0 009.958 7.967.75.75 0 011.067.853A8.5 8.5 0 116.647 1.921a.75.75 0 01.808.083z" clip-rule="evenodd" />
            </svg>
            Dark
          </button>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-2">Your preference is saved in this browser. You can also toggle with the button in the top navigation.</p>
      </div>
    </div>

    <!-- Sign Out -->
    <div class="bg-[var(--surface)] border border-red-200 rounded-2xl p-6">
      <h2 class="text-sm font-semibold text-red-600 uppercase tracking-widest mb-3">Session</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">Sign out of the client portal on this device.</p>
      <a
        href="/api/auth/sign-out"
        class="inline-flex items-center gap-2 rounded-xl border border-red-300 px-5 py-2.5 text-sm font-bold text-red-600 hover:bg-red-50 hover:border-red-400 transition-colors"
      >
        Sign Out
      </a>
    </div>

  </div>
</ClientLayout>

<script>
  function syncThemeButtons() {
    const isDark = document.documentElement.classList.contains('dark');
    const lightBtn = document.getElementById('theme-light-btn');
    const darkBtn = document.getElementById('theme-dark-btn');
    if (!lightBtn || !darkBtn) return;

    if (isDark) {
      darkBtn.className = 'inline-flex items-center gap-2 rounded-xl border border-[var(--accent)] bg-[var(--surface-hover)] px-4 py-2.5 text-sm font-medium text-[var(--accent)] transition-colors';
      lightBtn.className = 'inline-flex items-center gap-2 rounded-xl border border-[var(--border)] px-4 py-2.5 text-sm font-medium text-[var(--text-secondary)] hover:border-[var(--border-hover)] transition-colors';
    } else {
      lightBtn.className = 'inline-flex items-center gap-2 rounded-xl border border-[var(--accent)] bg-[var(--surface-hover)] px-4 py-2.5 text-sm font-medium text-[var(--accent)] transition-colors';
      darkBtn.className = 'inline-flex items-center gap-2 rounded-xl border border-[var(--border)] px-4 py-2.5 text-sm font-medium text-[var(--text-secondary)] hover:border-[var(--border-hover)] transition-colors';
    }
  }

  syncThemeButtons();

  document.getElementById('theme-light-btn')?.addEventListener('click', () => {
    document.documentElement.classList.remove('dark');
    localStorage.setItem('theme', 'light');
    syncThemeButtons();
  });

  document.getElementById('theme-dark-btn')?.addEventListener('click', () => {
    document.documentElement.classList.add('dark');
    localStorage.setItem('theme', 'dark');
    syncThemeButtons();
  });
</script>
