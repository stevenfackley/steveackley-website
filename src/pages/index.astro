---
import PublicLayout from '@/layouts/PublicLayout.astro';
import BentoDashboard from '@/components/bento/BentoDashboard.astro';
import { db, posts as postsTable } from '@/db';
import { eq, desc } from 'drizzle-orm';
import { getPublicRepos, enrichRepos } from '@/lib/github';
import { getSiteSettings, SETTING_KEYS } from '@/lib/settings';

// Fetch live blog posts for the preview
const blogPosts = await db
  .select()
  .from(postsTable)
  .where(eq(postsTable.published, true))
  .orderBy(desc(postsTable.createdAt))
  .limit(3);

// Fetch live GitHub repos
let githubRepos = [];
try {
  const rawRepos = await getPublicRepos();
  githubRepos = await enrichRepos(rawRepos);
} catch (e) {
  console.error("Failed to fetch GitHub repos:", e);
}

// Load settings from database
const settings = await getSiteSettings([
  SETTING_KEYS.AVATAR_URL,
  SETTING_KEYS.COUPLE_PHOTO_URL,
]);

const avatarUrl = settings[SETTING_KEYS.AVATAR_URL];
const couplePhotoUrl = settings[SETTING_KEYS.COUPLE_PHOTO_URL];
---

<PublicLayout title="Steve Ackley" description="Staff Software Engineer - .NET, Azure, Full-Stack">
  <div class="py-8">
    <BentoDashboard 
      blogPosts={blogPosts} 
      githubRepos={githubRepos} 
      avatarUrl={avatarUrl}
      couplePhotoUrl={couplePhotoUrl}
    />
  </div>
</PublicLayout>
