---
import Nav from '@/components/ui/Nav.astro';
import Footer from '@/components/ui/Footer.astro';
import '@/styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Steve Ackley', description = 'Staff Software Engineer - .NET, Azure, Full-Stack' } = Astro.props;
const fullTitle = title === 'Steve Ackley' ? title : `${title} | Steve Ackley`;
const avatarUrl = 'https://avatars.githubusercontent.com/u/stevenfackley';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href={avatarUrl} />
    <link rel="apple-touch-icon" href={avatarUrl} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    
    <style is:global>
      :root {
        --nav-height: 4rem;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-mesh selection:bg-blue-500/30">
    <Nav />
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
