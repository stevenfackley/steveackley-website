---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
}

const { title = 'Client Portal' } = Astro.props;
---

<BaseLayout title={title}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex gap-8">
      <!-- Sidebar -->
      <aside class="hidden md:block w-56 shrink-0">
        <nav class="space-y-1 sticky top-20">
          <a href="/client/dashboard" class="block px-3 py-2 text-sm rounded-lg text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] hover:text-[var(--text-primary)] transition-colors">Dashboard</a>
          <a href="/client/messages" class="block px-3 py-2 text-sm rounded-lg text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] hover:text-[var(--text-primary)] transition-colors">Messages</a>
          <a href="/client/account" class="block px-3 py-2 text-sm rounded-lg text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] hover:text-[var(--text-primary)] transition-colors">Account</a>
        </nav>
      </aside>

      <!-- Main content -->
      <div class="flex-1 min-w-0">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>
