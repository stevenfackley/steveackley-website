---
import Nav from '@/components/ui/Nav.astro';
import Footer from '@/components/ui/Footer.astro';
import '@/styles/globals.css';
import { getSiteSettings } from '@/lib/settings';
import { SETTING_KEYS } from '@/lib/setting-keys';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Steve Ackley', description = 'Staff Software Engineer - .NET, Azure, Full-Stack' } = Astro.props;
const fullTitle = title === 'Steve Ackley' ? title : `${title} | Steve Ackley`;
const avatarUrl = 'https://github.com/stevenfackley.png';

// Read site default theme from DB
let siteTheme = 'light';
try {
  const settings = await getSiteSettings([SETTING_KEYS.SITE_THEME]);
  siteTheme = settings[SETTING_KEYS.SITE_THEME] || 'light';
} catch {
  // If DB not available, default to light
}
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    
    <!-- Theme init: runs before paint to prevent flash -->
    <script is:inline define:vars={{ siteTheme }}>
      (function () {
        const stored = localStorage.getItem('theme');
        const theme = stored || siteTheme || 'light';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href={avatarUrl} />
    <link rel="apple-touch-icon" href={avatarUrl} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    
    <style is:global>
      :root {
        --nav-height: 4rem;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-mesh selection:bg-blue-500/30">
    <Nav />
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
