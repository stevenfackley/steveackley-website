---
import Nav from '@/components/ui/Nav.astro';
import Footer from '@/components/ui/Footer.astro';
import '@/styles/globals.css';
import { getSiteSettings } from '@/lib/settings';
import { SETTING_KEYS } from '@/lib/setting-keys';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  ogProfile?: { firstName: string; lastName: string; username: string };
  ogArticle?: { publishedTime: Date; modifiedTime: Date; author?: string };
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = 'Steve Ackley',
  description = 'Staff Software Engineer - .NET, Azure, Full-Stack',
  ogImage,
  ogType = 'website',
  ogProfile,
  ogArticle,
  noindex = false,
  jsonLd,
} = Astro.props;
const fullTitle = title.includes('Steve Ackley') ? title : `${title} | Steve Ackley`;
const faviconUrl = '/avatar.png';
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.toString();
const siteOrigin = Astro.site ? Astro.site.origin : 'https://steveackley.org';
const socialImage = ogImage ?? `${siteOrigin}/og-default.png`;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Steve Ackley',
  url: siteOrigin,
};

const pageSchemas: Array<Record<string, unknown>> = [websiteSchema];
if (jsonLd) {
  if (Array.isArray(jsonLd)) pageSchemas.push(...jsonLd);
  else pageSchemas.push(jsonLd);
}

// Read the site default theme from the DB. "system" (the default) means the
// pre-paint script below follows the visitor's OS prefers-color-scheme; an
// explicit "light"/"dark" admin setting overrides that.
let siteTheme = 'system';
try {
  const settings = await getSiteSettings([SETTING_KEYS.SITE_THEME]);
  siteTheme = settings[SETTING_KEYS.SITE_THEME] || 'system';
} catch {
  // If the DB is unavailable, fall back to following the OS preference.
}
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title="Steve Ackley — Blog" href="/rss.xml" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="Steve Ackley" />

    {ogProfile && (
      <>
        <meta property="profile:first_name" content={ogProfile.firstName} />
        <meta property="profile:last_name" content={ogProfile.lastName} />
        <meta property="profile:username" content={ogProfile.username} />
      </>
    )}
    {ogArticle && (
      <>
        <meta property="article:published_time" content={ogArticle.publishedTime.toISOString()} />
        <meta property="article:modified_time" content={ogArticle.modifiedTime.toISOString()} />
        <meta property="article:author" content={ogArticle.author ?? 'Steve Ackley'} />
      </>
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    
    <!-- Theme init: runs before paint to prevent a flash of the wrong theme.
         Also tags <html> with .js so scroll-reveal styles only hide content
         when JS can reveal it. Resolution mirrors resolveTheme() in
         src/lib/theme.ts (kept inline here so it can run before the bundle):
           persisted choice > explicit admin light/dark > OS prefers-color-scheme. -->
    <script is:inline define:vars={{ siteTheme }}>
      (function () {
        document.documentElement.classList.add('js');
        var stored = null;
        try { stored = localStorage.getItem('theme'); } catch (e) { /* storage blocked */ }
        var theme;
        if (stored === 'light' || stored === 'dark') {
          theme = stored;
        } else if (siteTheme === 'light' || siteTheme === 'dark') {
          theme = siteTheme;
        } else {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.classList.toggle('dark', theme === 'dark');
        document.documentElement.style.colorScheme = theme;
      })();
    </script>

    <!-- qav, watching from the inspector — Qavren Solutions brand signature -->
    <script is:inline>
      console.log(
        "%c >o) %c qav is watching",
        "color:#3b7bd6;font-size:16px;font-weight:bold;background:#1b2330;padding:3px 6px;border-radius:2px",
        "color:#5a6776;font-size:11px;margin-left:6px;font-family:monospace"
      );
    </script>
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href={faviconUrl} />
    <link rel="apple-touch-icon" href={faviconUrl} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    
    <style is:global>
      :root {
        --nav-height: 4rem;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <div class="aurora" aria-hidden="true"><span></span><span></span><span></span></div>
    <div class="noise" aria-hidden="true"></div>
    <Nav />
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>
    <Footer />

    <script>
      // ── Cursor spotlight ────────────────────────────────────────────────────
      // Delegated: only the card actually under the pointer gets its CSS vars
      // updated, so hundreds of cards cost nothing.
      const finePointer = window.matchMedia('(pointer: fine)');
      if (finePointer.matches) {
        document.addEventListener(
          'pointermove',
          (e) => {
            const card = (e.target as Element | null)?.closest?.('.spotlight-card');
            if (!card) return;
            const rect = card.getBoundingClientRect();
            (card as HTMLElement).style.setProperty('--spot-x', `${e.clientX - rect.left}px`);
            (card as HTMLElement).style.setProperty('--spot-y', `${e.clientY - rect.top}px`);
          },
          { passive: true }
        );
      }

      // ── Scroll reveal ───────────────────────────────────────────────────────
      // MutationObserver catches [data-reveal] nodes added later by hydrating
      // React islands — a load-time querySelectorAll would miss them.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );

      function watch(el: Element) {
        // React islands reveal their own [data-reveal] children after hydration —
        // mutating their class here mid-hydration triggers React mismatch errors.
        if (el.closest('astro-island')) return;
        if (reduceMotion.matches) {
          el.classList.add('is-revealed');
        } else {
          io.observe(el);
        }
      }

      document.querySelectorAll('[data-reveal]').forEach(watch);

      const mo = new MutationObserver((mutations) => {
        for (const m of mutations) {
          for (const node of m.addedNodes) {
            if (!(node instanceof Element)) continue;
            if (node.hasAttribute('data-reveal')) watch(node);
            node.querySelectorAll?.('[data-reveal]').forEach(watch);
          }
        }
      });
      mo.observe(document.body, { childList: true, subtree: true });
    </script>
  </body>
</html>
