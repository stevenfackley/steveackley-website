---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { ResumeSkills } from '@/components/resume/ResumeSkills';
import { ResumeEmailButton } from '@/components/resume/ResumeEmailButton';
import { getResumeContent } from '@/lib/content';
import { getSiteSetting, SETTING_KEYS } from '@/lib/settings';
import { resumePersonSchema, breadcrumbSchema } from '@/lib/seo';

const EMAIL = 'stevenfackley@gmail.com';
const LINKEDIN = 'https://www.linkedin.com/in/stevenackley';
const GITHUB_URL = 'https://github.com/stevenfackley';
const SITE_ORIGIN = 'https://steveackley.org';

const [avatarUrl, resumeContent] = await Promise.all([
  getSiteSetting(SETTING_KEYS.AVATAR_URL),
  getResumeContent(),
]);

const { summary, coreSkills, techTags, experience, certifications, education } = resumeContent;

const jsonLd = [
  resumePersonSchema(resumeContent, avatarUrl),
  breadcrumbSchema([
    { name: 'Home', url: SITE_ORIGIN },
    { name: 'Resume', url: `${SITE_ORIGIN}/resume` },
  ]),
];
---

<PublicLayout
  title="Resume"
  description="Staff Software Engineer at Lockheed Martin. .NET, Azure &amp; Angular specialist with 10+ years experience. Microsoft-certified. Open to consulting."
  ogType="profile"
  ogProfile={{ firstName: 'Steve', lastName: 'Ackley', username: 'stevenackley' }}
  jsonLd={jsonLd}
>
  <div class="min-h-screen">
    <div
      class="resume-hero relative overflow-hidden"
      style="background: linear-gradient(135deg, #1e3a8a 0%, #1e1b4b 50%, #4a1d96 100%);"
    >
      <div
        class="absolute -top-20 -right-20 h-80 w-80 rounded-full opacity-20 blur-3xl pointer-events-none"
        style="background: radial-gradient(circle, #60a5fa, transparent);"
        aria-hidden="true"
      />
      <div
        class="absolute -bottom-10 -left-10 h-60 w-60 rounded-full opacity-15 blur-3xl pointer-events-none"
        style="background: radial-gradient(circle, #a78bfa, transparent);"
        aria-hidden="true"
      />
      <div
        class="absolute inset-0 opacity-10 pointer-events-none"
        style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 28px 28px;"
        aria-hidden="true"
      />

      <div class="relative z-10 mx-auto max-w-5xl px-6 py-14 sm:py-20">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-7">
          <div class="relative shrink-0">
            <div
              class="absolute inset-0 rounded-full blur-md opacity-70"
              style="background: linear-gradient(135deg, #60a5fa, #a78bfa); transform: scale(1.15);"
              aria-hidden="true"
            />
            <img
              src={avatarUrl}
              alt="Steve Ackley"
              width="96"
              height="96"
              class="relative rounded-full ring-4 ring-white/20 object-cover"
            />
          </div>

          <div class="min-w-0 flex-1">
            <h1 id="resume-hero-name" class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight leading-none">
              Steve Ackley
            </h1>
            <p class="mt-2 text-lg text-blue-200 font-medium">
              Staff Software Engineer &nbsp;&middot;&nbsp; .NET &nbsp;&middot;&nbsp; Azure &nbsp;&middot;&nbsp; Full-Stack
            </p>

            <div class="mt-4 flex flex-wrap gap-2">
              {certifications.map((c) => (
                <span
                  class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold text-white border border-white/20"
                  style="background: rgba(255,255,255,0.12);"
                >
                  <span>{c.icon}</span>
                  {c.name}
                </span>
              ))}
              <span
                class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold text-white border border-white/20"
                style="background: rgba(255,255,255,0.12);"
              >
                <span class="h-2 w-2 rounded-full bg-emerald-400 pulse-dot inline-block" />
                Open to consulting & side projects
              </span>
            </div>

            <div class="mt-6 flex flex-wrap items-center gap-4">
              <a href={`mailto:${EMAIL}`} class="text-sm text-blue-200 hover:text-white transition-colors flex items-center gap-1.5">
                <span>&#9993;</span> {EMAIL}
              </a>
              <a href={LINKEDIN} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-200 hover:text-white transition-colors flex items-center gap-1.5">
                <span class="font-bold">in</span> LinkedIn
              </a>
              <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-200 hover:text-white transition-colors flex items-center gap-1.5">
                <span>&#9661;</span> GitHub
              </a>
              <span class="text-sm text-blue-200 flex items-center gap-1.5">
                <span>&#128205;</span> Derby, CT
              </span>
            </div>
          </div>

          <div class="shrink-0 no-print">
            <div class="flex flex-col gap-2">
              <a
                href="/steve-ackley-resume.pdf"
                download="Steve-Ackley-Resume.pdf"
                class="inline-flex items-center gap-2 rounded-xl px-5 py-3 text-sm font-semibold text-white bg-white/20 hover:bg-white/30 transition-all duration-200 backdrop-blur-sm border border-white/30"
              >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Download Resume
              </a>
              <p class="text-xs text-blue-200 text-center">Downloads clean PDF</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto max-w-5xl px-6 py-12 space-y-12">
      <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-7 card-glow">
        <h2 class="text-xs font-semibold tracking-widest uppercase text-[var(--text-muted)] mb-4">Professional Summary</h2>
        <p class="text-[var(--text-secondary)] leading-relaxed text-base">{summary}</p>
      </div>

      <div>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-[var(--text-muted)] mb-5 accent-bar">
          Technical Skills
        </h2>
        <ResumeSkills client:visible coreSkills={coreSkills} />
      </div>

      <div>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-[var(--text-muted)] mb-5 accent-bar">
          Work Experience
        </h2>
        <div class="relative">
          <div class="absolute left-5 top-2 bottom-2 w-px bg-[var(--border)]" aria-hidden="true" />
          <div class="space-y-0">
            {experience.map((item, i) => (
              <div class="relative flex gap-6 pb-8">
                <div class="relative z-10 mt-1 shrink-0">
                  <div
                    class="h-10 w-10 rounded-full flex items-center justify-center text-white text-xs font-bold shrink-0 ring-4 ring-[var(--background)]"
                    style="background: linear-gradient(135deg, #2563eb, #7c3aed);"
                  >
                    {i + 1}
                  </div>
                </div>
                <div class="flex-1 bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-5 hover:border-[var(--border-hover)] transition-colors">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
                    <div>
                      <h3 class="text-base font-semibold text-[var(--text-primary)]">{item.role}</h3>
                      <p class="text-sm font-medium text-[var(--accent)]">{item.company}</p>
                      <p class="text-xs text-[var(--text-muted)]">{item.location}</p>
                    </div>
                    <span
                      class="text-xs font-semibold px-2.5 py-1 rounded-full shrink-0 text-white"
                      style="background: linear-gradient(135deg, #2563eb, #7c3aed);"
                    >
                      {item.period}
                    </span>
                  </div>
                  <p class="text-sm text-[var(--text-secondary)] leading-relaxed mt-2">{item.body}</p>
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {item.tags.map((t) => (
                      <span class="text-xs px-2 py-0.5 rounded-md bg-[var(--surface-hover)] border border-[var(--border)] text-[var(--text-secondary)]">
                        {t}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-[var(--text-muted)] mb-5 accent-bar">
          Education
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {education.map((ed) => (
            <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-5 card-glow">
              <p class="text-sm font-bold text-[var(--text-primary)]">{ed.degree}</p>
              {ed.minor && <p class="text-xs text-[var(--text-muted)] mt-0.5">{ed.minor}</p>}
              <p class="text-sm text-[var(--accent)] mt-1">{ed.school}</p>
              <p class="text-xs text-[var(--text-muted)] mt-0.5">{ed.year}{ed.location ? ` · ${ed.location}` : ''}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-[var(--text-muted)] mb-5 accent-bar">
          Certifications
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {certifications.map((cert) => (
            <div class="flex items-center gap-5 bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-5 card-glow">
              <div
                class="h-14 w-14 rounded-2xl flex items-center justify-center text-2xl shrink-0"
                style={`background: ${cert.bg}; border: 1px solid ${cert.color}30;`}
              >
                {cert.icon}
              </div>
              <div>
                <p class="text-sm font-bold text-[var(--text-primary)]">{cert.name}</p>
                <p class="text-xs text-[var(--text-muted)] mt-0.5">{cert.issuer}</p>
                <div
                  class="mt-2 h-1 w-16 rounded-full"
                  style={`background: linear-gradient(90deg, ${cert.color}, transparent);`}
                />
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-xs font-semibold tracking-widest uppercase text-[var(--text-muted)] mb-5 accent-bar">
          Full Tech Stack
        </h2>
        <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl p-6">
          <div class="flex flex-wrap gap-2">
            {techTags.map((tag) => (
              <span class="text-sm px-3 py-1.5 rounded-xl border border-[var(--border)] bg-[var(--surface-hover)] text-[var(--text-secondary)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors duration-150 cursor-default">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </div>

      <div
        class="relative rounded-2xl overflow-hidden p-8 text-center"
        style="background: linear-gradient(135deg, #1e3a8a, #4a1d96);"
      >
        <div
          class="absolute inset-0 opacity-10 pointer-events-none"
          style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 24px 24px;"
          aria-hidden="true"
        />
        <div class="relative z-10">
          <p class="text-sm font-semibold text-blue-200 uppercase tracking-widest mb-2">Get In Touch</p>
          <h2 class="text-2xl font-bold text-white mb-3">Open to consulting and side projects</h2>
          <p class="text-blue-200 text-sm max-w-md mx-auto mb-6 leading-relaxed">
            Currently a Staff Software Engineer at Lockheed Martin. Available for contract consulting,
            freelance .NET / Azure architecture work, and technically interesting side projects.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center no-print">
            <ResumeEmailButton client:load />
            <a
              href={LINKEDIN}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-colors"
            >
              <span class="font-bold">in</span> Connect on LinkedIn
            </a>
            <a
              href="/steve-ackley-resume.pdf"
              download="Steve-Ackley-Resume.pdf"
              class="inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-colors"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Save as PDF
            </a>
          </div>
        </div>
      </div>

      <div class="text-center pb-4 no-print">
        <a href="/" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors">
          &larr; Back to home
        </a>
      </div>
    </div>
  </div>
</PublicLayout>
