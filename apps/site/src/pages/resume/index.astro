---
import PublicLayout from '@/layouts/PublicLayout.astro';
import { ResumeClient } from '@/components/ResumeClient';
import { getResumeContent } from '@/lib/content';
import { getSiteSetting, SETTING_KEYS } from '@/lib/settings';

const [avatarUrl, resumeContent] = await Promise.all([
  getSiteSetting(SETTING_KEYS.AVATAR_URL),
  getResumeContent(),
]);
---

<PublicLayout title="Resume" description="Steve Ackley - Staff Software Engineer resume">
  <ResumeClient client:load avatarUrl={avatarUrl} content={resumeContent} />
</PublicLayout>
