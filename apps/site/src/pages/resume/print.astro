---
import { getResumeContent } from '@/lib/content';
import '@/styles/globals.css';

const PHONE = '475-777-1139';
const EMAIL = 'stevenfackley@gmail.com';
const LINKEDIN = 'linkedin.com/in/stevenackley';
const GITHUB = 'github.com/stevenfackley';
const LOCATION = 'Derby, CT';
const SITE_ORIGIN = 'https://steveackley.org';

const { summary, coreSkills, techTags, experience, certifications, education } =
  await getResumeContent();

// Group consecutive experience entries by company (e.g. two Lockheed roles)
const experienceGroups: Array<{
  company: string;
  location: string;
  dateRange: string;
  roles: typeof experience;
}> = [];
for (const exp of experience) {
  const last = experienceGroups[experienceGroups.length - 1];
  if (last && last.company === exp.company) {
    last.roles.push(exp);
  } else {
    experienceGroups.push({
      company: exp.company,
      location: exp.location,
      dateRange: exp.period,
      roles: [exp],
    });
  }
}
// For grouped companies, span date range from oldest start to newest end
for (const group of experienceGroups) {
  if (group.roles.length > 1) {
    const oldest = group.roles[group.roles.length - 1].period.split(' - ')[0];
    const newest = group.roles[0].period.split(' - ')[1] ?? 'Present';
    group.dateRange = `${oldest} – ${newest}`;
  }
}

// Group skills by category for the print table
const CATEGORY_LABELS: Record<string, string> = {
  Microsoft: 'Microsoft Stack',
  Frontend: 'Frontend',
  Data: 'Data & BI',
  DevOps: 'DevOps & Cloud',
};
const skillsByCategory: Record<string, string[]> = {};
for (const s of coreSkills) {
  if (!skillsByCategory[s.category]) skillsByCategory[s.category] = [];
  skillsByCategory[s.category].push(s.name);
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={`${SITE_ORIGIN}/resume`} />
    <title>Steve Ackley - Resume</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      @page {
        size: letter;
        margin: 0.65in 0.7in;
      }
      * { box-sizing: border-box; }
      body {
        background: #f4f4f5;
        font-family: 'Georgia', 'Times New Roman', serif;
      }
      .resume-doc {
        max-width: 8.5in;
        margin: 2rem auto 4rem;
        background: #ffffff;
        box-shadow: 0 4px 32px rgba(0,0,0,0.18);
        padding: 0.7in 0.75in;
        color: #1a1a1a;
        font-size: 10.5pt;
        line-height: 1.45;
      }
      .doc-header {
        border-bottom: 2.5px solid #1e3a8a;
        padding-bottom: 0.55rem;
        margin-bottom: 0.75rem;
      }
      .doc-name-block { margin-bottom: 0.25rem; }
      .doc-name {
        font-size: 24pt;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: #0f172a;
        line-height: 1.1;
        font-family: 'Arial', 'Helvetica Neue', sans-serif;
      }
      .doc-title {
        font-size: 11pt;
        color: #1e3a8a;
        font-family: 'Arial', 'Helvetica Neue', sans-serif;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-top: 0.1rem;
      }
      .doc-contact {
        font-size: 8.5pt;
        color: #4b5563;
        font-family: 'Arial', 'Helvetica Neue', sans-serif;
        margin-top: 0.3rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
        align-items: center;
      }
      .doc-contact a { color: #1e3a8a; text-decoration: none; }
      .doc-sep { color: #9ca3af; font-size: 8pt; }
      .doc-section { margin-bottom: 0.75rem; }
      .doc-section-title {
        font-size: 10pt;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #1e3a8a;
        font-family: 'Arial', 'Helvetica Neue', sans-serif;
        border-bottom: 1px solid #bfdbfe;
        padding-bottom: 0.2rem;
        margin-bottom: 0.5rem;
      }
      .doc-text {
        font-size: 9.5pt;
        color: #374151;
        line-height: 1.5;
      }
      .doc-job { margin-bottom: 0.65rem; }
      .doc-job-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.1rem;
      }
      .doc-company {
        font-weight: 700;
        font-size: 10pt;
        color: #0f172a;
        font-family: 'Arial', 'Helvetica Neue', sans-serif;
      }
      .doc-job-location {
        font-size: 9pt;
        color: #6b7280;
      }
      .doc-date {
        font-size: 9pt;
        color: #6b7280;
        white-space: nowrap;
        font-style: italic;
      }
      .doc-role {
        font-size: 9.5pt;
        font-style: italic;
        color: #374151;
        margin-bottom: 0.25rem;
        font-family: 'Arial', 'Helvetica Neue', sans-serif;
      }
      .doc-role-date {
        font-size: 8.5pt;
        color: #6b7280;
        font-weight: 400;
      }
      .doc-role-block { margin-bottom: 0.35rem; }
      .doc-body-text {
        font-size: 9.5pt;
        color: #374151;
        line-height: 1.5;
        margin: 0.15rem 0 0.2rem 0;
      }
      .doc-tags {
        font-size: 8.5pt;
        color: #6b7280;
        font-style: italic;
        margin-top: 0.1rem;
      }
      .doc-skills-table { width: 100%; border-collapse: collapse; font-size: 9.5pt; }
      .doc-skills-table td { vertical-align: top; padding: 0.15rem 0.4rem 0.15rem 0; line-height: 1.45; }
      .doc-skill-label {
        font-weight: 700;
        color: #0f172a;
        white-space: nowrap;
        width: 140px;
        font-family: 'Arial', 'Helvetica Neue', sans-serif;
        font-size: 9pt;
      }
      .doc-certs { display: flex; flex-direction: column; gap: 0.3rem; }
      .doc-cert { display: flex; justify-content: space-between; align-items: baseline; font-size: 9.5pt; }
      .doc-cert-name { font-weight: 600; color: #0f172a; }
      .doc-cert-issuer { font-style: italic; color: #6b7280; font-size: 9pt; }
      @media print {
        body { background: white; }
        .no-print { display: none !important; }
        .resume-doc {
          max-width: none;
          margin: 0;
          padding: 0;
          box-shadow: none;
          font-size: 10pt;
        }
        .doc-header { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .doc-section-title { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .doc-job { page-break-inside: avoid; }
      }
      @media screen {
        .resume-doc { border-top: 4px solid #1e3a8a; }
      }
    </style>
  </head>
  <body>
    <div class="no-print" style="position:fixed;top:1rem;right:1rem;z-index:50;display:flex;gap:0.5rem;">
      <button
        onclick="window.print()"
        style="display:inline-flex;align-items:center;gap:0.5rem;border-radius:0.5rem;padding:0.5rem 1rem;font-size:0.875rem;font-weight:600;background:#2563eb;color:white;border:none;cursor:pointer;"
      >
        Save as PDF
      </button>
      <a
        href="/resume"
        style="display:inline-flex;align-items:center;gap:0.5rem;border-radius:0.5rem;padding:0.5rem 1rem;font-size:0.875rem;font-weight:600;background:white;border:1px solid #e5e7eb;color:#374151;text-decoration:none;"
      >
        Back
      </a>
    </div>

    <div id="resume-doc" class="resume-doc">
      <header class="doc-header">
        <div class="doc-name-block">
          <h1 class="doc-name">Steve Ackley</h1>
          <p class="doc-title">Staff Software Engineer</p>
        </div>
        <div class="doc-contact">
          <span>{PHONE}</span>
          <span class="doc-sep">|</span>
          <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
          <span class="doc-sep">|</span>
          <span>{LOCATION}</span>
          <span class="doc-sep">|</span>
          <span>{LINKEDIN}</span>
          <span class="doc-sep">|</span>
          <span>{GITHUB}</span>
        </div>
      </header>

      <section class="doc-section">
        <h2 class="doc-section-title">Professional Summary</h2>
        <p class="doc-text">{summary}</p>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">Work Experience</h2>
        {experienceGroups.map((group) => (
          <div class="doc-job">
            <div class="doc-job-header">
              <div>
                <span class="doc-company">{group.company}</span>
                {group.location && <span class="doc-job-location"> &mdash; {group.location}</span>}
              </div>
              <span class="doc-date">{group.dateRange}</span>
            </div>
            {group.roles.map((role) => (
              <div class="doc-role-block">
                {group.roles.length > 1
                  ? <p class="doc-role">{role.role} <span class="doc-role-date">({role.period})</span></p>
                  : <p class="doc-role">{role.role}</p>
                }
                <p class="doc-body-text">{role.body}</p>
                {role.tags.length > 0 && (
                  <p class="doc-tags">Stack: {role.tags.join(', ')}</p>
                )}
              </div>
            ))}
          </div>
        ))}
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">Technical Skills</h2>
        <table class="doc-skills-table">
          <tbody>
            {Object.entries(skillsByCategory).map(([cat, skills]) => (
              <tr>
                <td class="doc-skill-label">{CATEGORY_LABELS[cat] ?? cat}</td>
                <td>{skills.join(', ')}</td>
              </tr>
            ))}
            <tr>
              <td class="doc-skill-label">Full Stack</td>
              <td>{techTags.join(', ')}</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">Certifications</h2>
        <div class="doc-certs">
          {certifications.map((cert) => (
            <div class="doc-cert">
              <span class="doc-cert-name">{cert.name}</span>
              <span class="doc-cert-issuer">{cert.issuer}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="doc-section">
        <h2 class="doc-section-title">Education</h2>
        {education.map((ed, i) => (
          <div class="doc-job" style={i === education.length - 1 ? 'margin-bottom: 0;' : ''}>
            <div class="doc-job-header">
              <div>
                <span class="doc-company">{ed.school}</span>
                {ed.location && <span class="doc-job-location"> &mdash; {ed.location}</span>}
              </div>
              <span class="doc-date">{ed.year}</span>
            </div>
            <p class="doc-role">{ed.degree}{ed.minor ? ` — ${ed.minor}` : ''}</p>
          </div>
        ))}
      </section>
    </div>

    <script>
      setTimeout(() => window.print(), 600);
    </script>
  </body>
</html>
