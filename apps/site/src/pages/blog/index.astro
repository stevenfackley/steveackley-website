---
import PublicLayout from '@/layouts/PublicLayout.astro';
import PostList from '@/components/blog/PostList.astro';
import Pagination from '@/components/blog/Pagination.astro';
import { db, posts as postsTable } from '@/db';
import { eq, desc, count } from 'drizzle-orm';
import type { PaginationInfo } from '@/types';

const SITE_ORIGIN = 'https://steveackley.org';

const PER_PAGE = 10;
const page = Number(Astro.url.searchParams.get('page') ?? '1');
const currentPage = Math.max(1, page);

// Get total count of published posts
const [totalCountResult] = await db
  .select({ value: count() })
  .from(postsTable)
  .where(eq(postsTable.published, true));

const totalItems = totalCountResult?.value || 0;
const totalPages = Math.ceil(totalItems / PER_PAGE);

// Get paginated posts
const posts = await db
  .select()
  .from(postsTable)
  .where(eq(postsTable.published, true))
  .orderBy(desc(postsTable.createdAt))
  .limit(PER_PAGE)
  .offset((currentPage - 1) * PER_PAGE);

const pagination: PaginationInfo = {
  currentPage,
  totalPages,
  totalItems,
  itemsPerPage: PER_PAGE,
  hasPreviousPage: currentPage > 1,
  hasNextPage: currentPage < totalPages,
};

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Blog – Steve Ackley',
  description: 'Writing on .NET, Azure, software architecture, and engineering practices.',
  url: `${SITE_ORIGIN}/blog`,
  author: { '@type': 'Person', name: 'Steve Ackley', url: SITE_ORIGIN },
  ...(posts.length > 0 && {
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: posts.map((p, i) => ({
        '@type': 'ListItem',
        position: (currentPage - 1) * PER_PAGE + i + 1,
        url: `${SITE_ORIGIN}/blog/${p.slug}`,
        name: p.title,
      })),
    },
  }),
};
---

<PublicLayout
  title="Blog"
  description="Writing on .NET, Azure, software architecture, and engineering practices."
  jsonLd={blogJsonLd}
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <header class="mb-12">
      <h1 class="text-3xl font-bold text-[var(--text-primary)]">Blog</h1>
      <p class="mt-2 text-[var(--text-secondary)]">
        Thoughts on software, technology, and whatever else I find interesting.
      </p>
    </header>

    {posts.length > 0 ? (
      <>
        <PostList posts={posts} />
        {totalPages > 1 && <Pagination pagination={pagination} basePath="/blog" />}
      </>
    ) : (
      <div class="text-center py-20">
        <p class="text-[var(--text-secondary)]">No posts found. Check back later!</p>
      </div>
    )}
  </div>
</PublicLayout>
