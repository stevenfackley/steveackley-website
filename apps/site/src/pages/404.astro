---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Not Found" description="Page not found" noindex={true}>
  <div class="min-h-[70vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-lg w-full text-center">
      <h1 class="font-display gradient-text-animated animate-float-slow text-[8rem] sm:text-[10rem] font-extrabold leading-none select-none">
        404
      </h1>
      <div class="glass-card spotlight-card rounded-3xl p-8 -mt-6">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-[var(--text-primary)]">
          This page drifted off
        </h2>
        <p class="mt-3 text-sm text-[var(--text-secondary)] leading-relaxed">
          The page you're looking for was moved, deleted, or never shipped.
        </p>
        <p class="mt-2 font-mono text-xs text-[var(--text-muted)]">
          HTTP 404 · route not matched
        </p>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_30px_var(--accent-glow)]"
            style="background: linear-gradient(135deg, var(--gradient-start), var(--gradient-mid));"
          >
            Return Home
          </a>
          <a
            href="/blog"
            class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold glass-card text-[var(--text-primary)] transition-all duration-200 hover:-translate-y-0.5"
          >
            Read the Blog
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
