---
import ClientLayout from '@/layouts/ClientLayout.astro';

if (!Astro.locals.user || Astro.locals.user.role !== 'CLIENT') {
  return Astro.redirect('/login');
}
---

<ClientLayout title="Messages">
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <section class="rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--text-muted)]">Inbox Route</p>
        <span class="rounded-full border border-[var(--border)] px-2.5 py-0.5 text-xs text-[var(--text-secondary)]">Messages</span>
      </div>
      <h2 class="text-lg font-semibold text-[var(--text-primary)] mb-2">A dedicated home for client communication.</h2>
      <p class="text-sm text-[var(--text-secondary)]">
        The visual shell is in place for a session-aware inbox, message threads, and reply actions. When live data
        lands, this route will not need structural redesign.
      </p>
    </section>

    <section class="rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6">
      <div class="flex items-center justify-between mb-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--text-muted)]">Expected flow</p>
        <span class="rounded-full border border-[var(--border)] px-2.5 py-0.5 text-xs text-[var(--text-secondary)]">Conversation view</span>
      </div>
      <ul class="space-y-2 text-sm text-[var(--text-secondary)]">
        <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-[var(--accent)] shrink-0"></span>Recent conversations with unread emphasis</li>
        <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-[var(--accent)] shrink-0"></span>Project-linked updates and status responses</li>
        <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-[var(--accent)] shrink-0"></span>Clean thread view that keeps client context intact</li>
      </ul>
    </section>
  </div>
</ClientLayout>
