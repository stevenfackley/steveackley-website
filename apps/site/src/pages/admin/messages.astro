---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getRecentMessages } from '@/lib/dashboard';

if (!Astro.locals.user || Astro.locals.user.role !== 'ADMIN') {
  return Astro.redirect('/login');
}

const messages = await getRecentMessages();
---

<AdminLayout title="Messages">
  <div class="space-y-6">
    <h1 class="text-2xl font-semibold text-[var(--text-primary)]">Messages</h1>

    <div class="bg-[var(--surface)] border border-[var(--border)] rounded-2xl overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-[var(--border)] bg-[var(--surface-hover)]">
            <th class="text-left px-4 py-3 font-medium text-[var(--text-muted)]">Subject</th>
            <th class="text-left px-4 py-3 font-medium text-[var(--text-muted)] hidden sm:table-cell">Type</th>
            <th class="text-left px-4 py-3 font-medium text-[var(--text-muted)]">Read</th>
            <th class="text-left px-4 py-3 font-medium text-[var(--text-muted)] hidden md:table-cell">Received</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[var(--border)]">
          {messages.length === 0 ? (
            <tr>
              <td colspan="4" class="px-4 py-10 text-center text-[var(--text-muted)]">No messages.</td>
            </tr>
          ) : messages.map((msg) => (
            <tr class={['hover:bg-[var(--surface-hover)] transition-colors', !msg.read ? 'font-medium' : ''].join(' ')}>
              <td class="px-4 py-3 max-w-xs">
                <p class="text-[var(--text-primary)] truncate">{msg.subject}</p>
                <p class="text-xs text-[var(--text-muted)] truncate mt-0.5">{msg.body.slice(0, 80)}{msg.body.length > 80 ? '…' : ''}</p>
              </td>
              <td class="px-4 py-3 hidden sm:table-cell">
                <span class={[
                  'inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium',
                  msg.type === 'PROJECT_REQUEST'
                    ? 'bg-[var(--accent)]/15 text-[var(--accent)]'
                    : 'bg-[var(--surface-hover)] text-[var(--text-muted)]',
                ].join(' ')}>
                  {msg.type === 'PROJECT_REQUEST' ? 'Project Request' : 'General'}
                </span>
              </td>
              <td class="px-4 py-3">
                {msg.read ? (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-[var(--surface-hover)] text-[var(--text-muted)]">Read</span>
                ) : (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-[var(--accent)]/15 text-[var(--accent)]">Unread</span>
                )}
              </td>
              <td class="px-4 py-3 text-[var(--text-muted)] hidden md:table-cell">
                {msg.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
