---
const linkedin = import.meta.env.PUBLIC_LINKEDIN_URL ?? 'https://www.linkedin.com/in/stevenackley';
const email = import.meta.env.PUBLIC_EMAIL ?? 'stevenfackley@gmail.com';
const year = new Date().getFullYear();

const isLoggedIn = !!Astro.locals.user;
---

<footer class="relative mt-auto py-10 before:absolute before:top-0 before:left-0 before:right-0 before:h-px before:bg-gradient-to-r before:from-transparent before:via-[var(--gradient-mid)] before:to-transparent before:opacity-40">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-center sm:text-left">
        <p class="font-display text-sm font-semibold text-[var(--text-primary)]">Steve Ackley</p>
        <p class="mt-1 text-xs text-[var(--text-muted)]">
          &copy; {year} · All rights reserved
        </p>
      </div>
      <div class="flex items-center gap-5">
        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors"
        >
          LinkedIn
        </a>
        <a
          href={`mailto:${email}`}
          class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors"
        >
          Email
        </a>
        {!isLoggedIn && (
          <a
            href="/login"
            class="text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors"
          >
            Sign In
          </a>
        )}
      </div>
    </div>
  </div>
</footer>
