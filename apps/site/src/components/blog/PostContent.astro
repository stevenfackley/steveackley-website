---
import DOMPurify from 'isomorphic-dompurify';

interface Props {
  content: string;
}

const { content } = Astro.props;
// content is admin-authored HTML from the TipTap editor (stored as-is in the DB).
// Sanitize before set:html so a compromised admin session / stored payload can't
// inject script into every visitor's page.
const safeContent = DOMPurify.sanitize(content);
---

<!--
  Code-block + inline-code styling lives in globals.css (.prose pre, .prose code,
  .prose pre code). It uses CSS variables that flip with light/dark mode, so any
  Tailwind prose-{pre,code}: modifiers here would only fight that cascade.
  Keep the modifiers in this file scoped to non-code prose elements only.
-->
<div
  class="prose prose-neutral dark:prose-invert max-w-none
    prose-headings:font-semibold prose-headings:tracking-tight
    prose-h2:mt-12 prose-h2:mb-4 prose-h3:mt-8 prose-h3:mb-3
    prose-p:leading-relaxed
    prose-a:text-[var(--accent)] prose-a:no-underline hover:prose-a:underline prose-a:font-medium
    prose-strong:text-[var(--text-primary)]
    prose-li:marker:text-[var(--accent)]
    prose-blockquote:border-l-[var(--accent)] prose-blockquote:not-italic prose-blockquote:font-normal prose-blockquote:text-[var(--text-secondary)]
    prose-hr:border-[var(--border)]
    prose-img:rounded-xl
    prose-code:before:content-none prose-code:after:content-none"
  set:html={safeContent}
/>
