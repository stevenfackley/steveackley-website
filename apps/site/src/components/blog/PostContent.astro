---
interface Props {
  content: string;
}

const { content } = Astro.props;
---

<!--
  Code-block + inline-code styling lives in globals.css (.prose pre, .prose code,
  .prose pre code). It uses CSS variables that flip with light/dark mode, so any
  Tailwind prose-{pre,code}: modifiers here would only fight that cascade.
  Keep the modifiers in this file scoped to non-code prose elements only.
-->
<div
  class="prose prose-neutral dark:prose-invert max-w-none
    prose-headings:font-semibold
    prose-a:text-[var(--accent)] prose-a:no-underline hover:prose-a:underline
    prose-img:rounded-xl
    prose-code:before:content-none prose-code:after:content-none"
  set:html={content}
/>
