# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
**/.next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets
.env
.env.local
.env.production
web.env

# env.example files are safe to commit (no real values)
!.env.example
!.env.tunnel.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Uploads (volume-managed in Docker) — anchored to root so src/app/api/uploads/ is NOT ignored
/uploads/

# Rewrite backup — local reference only, deleted before merge
/_backup/

# Prisma generated
node_modules/.prisma/

# Cloudflare Origin Certificate (placed on server only, never committed)
server/certs/

# Docker secrets (generated by CI/CD, never committed)
secrets/

# Migration Backups
src/_backup/

# Astro cache/generated
/.astro/
**/.astro/

# Build output
/dist/
apps/*/dist/

# .NET build artifacts
**/obj/
