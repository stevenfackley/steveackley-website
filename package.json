{
  "name": "steveackley-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:site": "npm run dev -w apps/site",
    "dev:portal": "npm run dev -w apps/portal",
    "build:site": "npm run build -w apps/site",
    "build:portal": "npm run build -w apps/portal",
    "test:site": "npm run test -w apps/site",
    "test:site:health": "npm run test:health -w apps/site",
    "test:portal": "npm run test -w apps/portal",
    "lint:site": "npm run lint -w apps/site",
    "lint:portal": "npm run lint -w apps/portal",
    "typecheck:site": "npm run typecheck -w apps/site",
    "typecheck:portal": "npm run typecheck -w apps/portal",
    "build": "npm run build:site && npm run build:portal",
    "test": "npm run test:site && npm run test:portal",
    "lint": "npm run lint:site && npm run lint:portal",
    "typecheck": "npm run typecheck:site && npm run typecheck:portal"
  }
}
