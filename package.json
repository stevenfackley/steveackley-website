{
  "name": "steveackley-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:site": "npm run dev -w apps/site",
    "build:site": "npm run build -w apps/site",
    "test:site": "npm run test -w apps/site",
    "test:site:health": "npm run test:health -w apps/site",
    "lint:site": "npm run lint -w apps/site",
    "typecheck:site": "npm run typecheck -w apps/site",
    "build": "npm run build:site",
    "test": "npm run test:site",
    "lint": "npm run lint:site",
    "typecheck": "npm run typecheck:site"
  },
  "overrides": {
    "hono": "^4.12.14",
    "dompurify": "^3.4.0",
    "yaml": "^2.8.3",
    "esbuild": "^0.25.0"
  }
}
